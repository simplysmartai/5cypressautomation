---
/**
 * Button.astro
 * Props:
 *   variant  "primary" | "secondary" | "ghost"   (default: "primary")
 *   size     "sm" | "md" | "lg"                  (default: "md")
 *   href     string  renders an <a> tag when set
 *   type     "button" | "submit" | "reset"       (default: "button")
 *   magnetic boolean  enable magnetic hover effect
 *   ripple   boolean  enable ripple click effect
 *   class    string   extra CSS classes
 */
interface Props {
  variant?: 'primary' | 'secondary' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  href?: string;
  type?: 'button' | 'submit' | 'reset';
  magnetic?: boolean;
  ripple?: boolean;
  class?: string;
  [key: string]: unknown;
}

const {
  variant = 'primary',
  size = 'md',
  href,
  type = 'button',
  magnetic = true,
  ripple = true,
  class: extraClass = '',
  ...rest
} = Astro.props;

const tag   = href ? 'a' : 'button';
const attrs = href
  ? { href, ...rest }
  : { type, ...rest };
---

{tag === 'a' ? (
  <a
    class={`btn btn-${variant} btn-${size}${extraClass ? ' ' + extraClass : ''}`}
    data-magnetic={magnetic || undefined}
    data-ripple={ripple || undefined}
    {...attrs}
  >
    <slot />
  </a>
) : (
  <button
    class={`btn btn-${variant} btn-${size}${extraClass ? ' ' + extraClass : ''}`}
    data-magnetic={magnetic || undefined}
    data-ripple={ripple || undefined}
    {...attrs}
  >
    <slot />
  </button>
)}

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    border-radius: var(--radius-full);
    font-family: var(--font-heading);
    font-weight: var(--weight-semibold);
    white-space: nowrap;
    cursor: pointer;
    border: 1px solid transparent;
    transition:
      background var(--duration-fast) var(--ease-out),
      border-color var(--duration-fast) var(--ease-out),
      box-shadow var(--duration-fast) var(--ease-out),
      transform var(--duration-fast) var(--ease-out);
    position: relative;
    overflow: hidden;
  }

  /* Sizes */
  .btn-sm  { padding: var(--space-1) var(--space-4); font-size: var(--text-xs); }
  .btn-md  { padding: var(--space-2) var(--space-5); font-size: var(--text-sm); }
  .btn-lg  { padding: var(--space-4) var(--space-8); font-size: var(--text-base); }

  /* Variants */
  .btn-primary {
    background: var(--brand-primary);
    color: var(--text-primary);
    border-color: var(--brand-primary);
  }
  .btn-primary:hover {
    background: var(--brand-primary-dark);
    border-color: var(--brand-primary-dark);
    box-shadow: var(--shadow-glow);
  }

  .btn-secondary {
    background: transparent;
    color: var(--text-primary);
    border-color: var(--border-medium);
  }
  .btn-secondary:hover {
    background: var(--bg-surface);
    border-color: var(--border-strong);
  }

  .btn-ghost {
    background: transparent;
    color: var(--text-secondary);
    border-color: transparent;
  }
  .btn-ghost:hover {
    color: var(--text-primary);
    background: var(--bg-surface);
  }

  /* Ripple wave (injected by Layout.astro script) */
  :global(.ripple-wave) {
    position: absolute;
    border-radius: 50%;
    width: 4px;
    height: 4px;
    background: rgba(255, 255, 255, 0.3);
    transform: translate(-50%, -50%) scale(0);
    animation: ripple-expand 0.5s var(--ease-out) forwards;
    pointer-events: none;
  }
  @keyframes ripple-expand {
    to { transform: translate(-50%, -50%) scale(120); opacity: 0; }
  }

  .btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
    transform: none !important;
  }
</style>
