---
/**
 * StatTile.astro — Big-number stat block
 * Used in a horizontal stat row (Karbon-style).
 */
interface Props {
  stat: string;
  label: string;
  subtext?: string;
}
const { stat, label, subtext } = Astro.props;
---

<div class="stat-tile">
  <p class="stat-number">{stat}</p>
  <p class="stat-label">{label}</p>
  {subtext && <p class="stat-sub">{subtext}</p>}
</div>

<style>
  .stat-tile {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-10) var(--space-8);
    border-right: 1px solid var(--border-subtle);
    flex: 1;
  }
  .stat-tile:last-child { border-right: none; }

  .stat-number {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: var(--weight-bold);
    font-style: italic;
    line-height: 1;
    background: var(--gradient-primary);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    letter-spacing: var(--tracking-tighter);
  }

  .stat-label {
    font-family: var(--font-heading);
    font-size: var(--text-base);
    font-weight: var(--weight-semibold);
    color: var(--text-primary);
    line-height: var(--leading-snug);
  }

  .stat-sub {
    font-size: var(--text-xs);
    color: var(--text-tertiary);
    font-family: var(--font-mono);
  }

  @media (max-width: 768px) {
    .stat-tile {
      border-right: none;
      border-bottom: 1px solid var(--border-subtle);
      padding: var(--space-8) 0;
    }
    .stat-tile:last-child { border-bottom: none; }
  }
</style>
