---
/**
 * Card.astro — Service/feature card
 * Props:
 *   icon        string  SVG path data or inline SVG string
 *   title       string
 *   description string
 *   href        string  optional — makes card a link
 *   tag         string  optional eyebrow label
 *   highlight   boolean optional gold accent glow
 */
interface Props {
  title: string;
  description: string;
  href?: string;
  tag?: string;
  highlight?: boolean;
}
const { title, description, href, tag, highlight = false } = Astro.props;
---

{href ? (
  <a href={href} class={`card${highlight ? ' card--highlight' : ''}`}>
    <div class="card-icon-slot">
      <slot name="icon" />
    </div>
    {tag && <p class="card-tag">{tag}</p>}
    <h3 class="card-title">{title}</h3>
    <p class="card-desc">{description}</p>
    <span class="card-arrow" aria-hidden="true">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M7 17L17 7M17 7H7M17 7v10"/>
      </svg>
    </span>
  </a>
) : (
  <div class={`card${highlight ? ' card--highlight' : ''}`}>
    <div class="card-icon-slot">
      <slot name="icon" />
    </div>
    {tag && <p class="card-tag">{tag}</p>}
    <h3 class="card-title">{title}</h3>
    <p class="card-desc">{description}</p>
  </div>
)}

<style>
  .card {
    position: relative;
    background: var(--bg-surface);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-xl);
    padding: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    transition:
      border-color var(--duration-normal) var(--ease-out),
      box-shadow var(--duration-normal) var(--ease-out),
      transform var(--duration-normal) var(--ease-out);
    text-decoration: none;
    color: inherit;
  }
  .card:hover {
    border-color: var(--border-brand);
    box-shadow: var(--shadow-glow);
    transform: translateY(-4px);
  }
  .card--highlight {
    border-color: rgba(251,191,36, 0.2);
    background: linear-gradient(135deg, var(--bg-surface) 0%, rgba(251,191,36,0.04) 100%);
  }
  .card--highlight:hover {
    border-color: rgba(251,191,36, 0.4);
    box-shadow: var(--shadow-glow-accent);
  }

  .card-icon-slot :global(svg) {
    width: 40px;
    height: 40px;
    color: var(--brand-primary);
    stroke: currentColor;
  }

  .card-tag {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--brand-primary);
  }

  .card-title {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    font-weight: var(--weight-bold);
    color: var(--text-primary);
    line-height: var(--leading-snug);
  }

  .card-desc {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    flex: 1;
  }

  .card-arrow {
    align-self: flex-end;
    color: var(--text-disabled);
    transition: color var(--duration-fast), transform var(--duration-fast);
  }
  .card:hover .card-arrow {
    color: var(--brand-primary);
    transform: translate(3px, -3px);
  }
</style>
