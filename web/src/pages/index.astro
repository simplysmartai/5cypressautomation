---
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';
import Card from '../components/Card.astro';
import StatTile from '../components/StatTile.astro';
import Faq from '../components/Faq.astro';
import MicroDashboard from '../components/MicroDashboard.astro';
import JsonLd from '../components/JsonLd.astro';

const services = [
  {
    tag: 'Dashboard',
    title: 'Practice KPI Dashboard',
    description:
      'Real-time realization rate, WIP, AR aging, and billing metrics — pulled from QBO + your practice management system and surfaced to every partner in one live panel.',
    href: '/services/practice-kpi-dashboard',
  },
  {
    tag: 'Reporting',
    title: 'Monthly Client Snapshot',
    description:
      'One click after QBO close: auto-generated PDF report + branded web dashboard per client, delivered before the 5th — no manual data pulls, no formatting.',
    href: '/services/monthly-client-snapshot',
  },
  {
    tag: 'AI · Intake',
    title: 'Document Intake & AI Sort',
    description:
      'Clients upload to a shared portal. OpenAI Vision classifies each file and routes it to the right job in Karbon, TaxDome, or SharePoint — in seconds.',
    href: '/services/document-intake-ai-sort',
    highlight: true,
  },
  {
    tag: 'Onboarding',
    title: 'Engagement → Onboarding Flow',
    description:
      'When a DocuSign engagement letter is signed, the system auto-creates the Karbon job, adds the client to QBO, and books their kickoff call via Calendly — hands-free.',
    href: '/services/engagement-onboarding-flow',
  },
  {
    tag: 'Lead Recovery',
    title: 'Missed-Lead Text-Back',
    description:
      'A prospect calls after hours or submits a form. They get a personalized text in under 60 seconds — before they move on to your competitor.',
    href: '/services/missed-lead-text-back',
  },
  {
    tag: 'Close · Flagship',
    title: 'Month-End Close Accelerator',
    description:
      'An agentic close engine that runs reconciliations, flags variances, drafts adjusting JEs for review, and pushes a partner-ready close package — same day QBO is locked.',
    href: '/services/month-end-close-accelerator',
    highlight: true,
  },
  {
    tag: 'AR · Cashflow',
    title: 'AR / Collections Agent',
    description:
      'Aging invoices chased automatically with a graduated 15/30/45/60 day cadence — tone-matched to the client relationship and escalated to a partner only when needed.',
    href: '/services/ar-collections-agent',
  },
  {
    tag: 'Advisory · Forecast',
    title: 'Cashflow Forecast Agent',
    description:
      'A 13-week rolling cashflow forecast per client, refreshed every morning from QBO actuals — with auto-alerts for low balance projections and covenant risks.',
    href: '/services/cashflow-forecast-agent',
  },
];

const faqs = [
  {
    question: 'Do you replace our existing tools — QBO, Karbon, TaxDome?',
    answer:
      'No. We build the connective tissue between them. Your team keeps using the tools they already know; the automations work invisibly in the background to eliminate the manual steps between systems.',
  },
  {
    question: 'How long does a typical engagement take to go live?',
    answer:
      'Most projects are live in 14 business days from kickoff. More complex workflows — like multi-system onboarding flows — typically take 3–4 weeks. We scope that clearly upfront.',
  },
  {
    question: 'What does it cost?',
    answer:
      'Setup ranges from $997 for focused automations (missed-lead text-back, single workflow) up to $4,500 for our flagship builds (Month-End Close Accelerator, Cashflow Forecast Agent). Ongoing automation maintenance is $100–$700/mo depending on scope.',
  },
  {
    question: "We're a small firm — is this overkill?",
    answer:
      'Two-partner firms often see the fastest ROI. If partners are spending 2+ hours a month on data entry or client reporting, the automation pays for itself in the first billing cycle.',
  },
  {
    question: 'Who maintains it after delivery?',
    answer:
      'You get full documentation and a runbook. For clients on a maintenance plan, we monitor, update, and expand the system as your tools evolve — no technical staff required on your end.',
  },
  {
    question: 'Do you work with fractional CFO practices, or only CPA firms?',
    answer:
      'Both. Fractional CFOs typically need the Monthly Client Snapshot and onboarding flow most. CPA firms tend to start with Practice KPI dashboards and document intake. We scope based on your specific workflow gaps.',
  },
];

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: '5 Cypress Automation',
  url: 'https://www.5cypress.com',
  logo: 'https://www.5cypress.com/logo.svg',
  email: 'nick@5cypress.com',
  description:
    'Automation systems for accounting and finance firms — Practice KPI dashboards, client reporting, document intake, and onboarding flows built on QBO, Karbon, TaxDome, and OpenAI.',
  sameAs: [],
};

const serviceSchemas = services.map((s) => ({
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'Business Automation',
  name: s.title,
  description: s.description,
  provider: {
    '@type': 'Organization',
    name: '5 Cypress Automation',
    url: 'https://www.5cypress.com',
  },
  areaServed: { '@type': 'Country', name: 'United States' },
}));
---

<Layout
  title="Automation for Accounting & Finance Firms | 5 Cypress"
  description="We build the systems that eliminate data entry, accelerate month-end close, and put real-time KPIs in front of every partner — without replacing the tools you already use."
>
  <Fragment slot="head">
    <JsonLd schema={orgSchema} />
    <JsonLd schema={serviceSchemas} />
  </Fragment>

  <!-- ══════════════════════════════════════════════════════════
       HERO
  ═══════════════════════════════════════════════════════════════ -->
  <section class="hero section">
    <div class="container hero-inner">
      <div class="hero-copy reveal">
        <p class="lead-in">Built for accounting &amp; finance firms</p>
        <h1>Your firm's busywork,&nbsp;<em>automated.</em></h1>
        <p class="hero-sub">
          We build the systems that eliminate data entry, accelerate month-end close,
          and put real-time KPIs in front of every partner — without replacing the tools you already use.
        </p>
        <div class="hero-ctas">
          <Button variant="primary" size="lg" magnetic ripple data-open-booking>
            Book a 20-min fit call
          </Button>
          <Button variant="secondary" size="lg" href="/services/practice-kpi-dashboard">
            See the Practice Dashboard
          </Button>
        </div>
        <p class="hero-proof">
          <span>15+ hrs saved per month</span>
          <span class="sep">·</span>
          <span>14 days to live</span>
          <span class="sep">·</span>
          <span>From $997</span>
        </p>
      </div>

      <div class="hero-visual reveal">
        <MicroDashboard variant="practice-kpi" />
        <div class="hero-visual-glow" aria-hidden="true"></div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════════
       PAIN POINTS
  ═══════════════════════════════════════════════════════════════ -->
  <section class="section pain-section">
    <div class="container">
      <div class="section-header reveal">
        <h2>Sound familiar?</h2>
        <p class="section-sub">
          These aren't technology problems — they're workflow problems.
          And they're costing your partners billable hours every week.
        </p>
      </div>
      <div class="pain-grid reveal-stagger">
        {[
          {
            num: '01',
            pain: 'Manual sync between QBO and your practice management system — every billing cycle.',
          },
          {
            num: '02',
            pain: 'Month-end client reports take 2–4 hours per client to pull, format, and send.',
          },
          {
            num: '03',
            pain: "Tax season document chaos: clients emailing files to whoever's available.",
          },
          {
            num: '04',
            pain: 'No live visibility into realization rate, WIP, or AR aging — until month-end.',
          },
        ].map(({ num, pain }) => (
          <div class="pain-item">
            <span class="pain-num">{num}</span>
            <p class="pain-text">{pain}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════════
       SERVICES
  ═══════════════════════════════════════════════════════════════ -->
  <section class="section" id="services">
    <div class="container">
      <div class="section-header reveal">
        <h2>Eight automations.<br/><em>Purpose-built for your practice.</em></h2>
        <p class="section-sub">
          Each system is scoped, built, and documented for your specific stack —
          not a generic tool you're expected to configure yourself.
        </p>
      </div>
      <div class="services-grid reveal-stagger">
        {services.map((s) => (
          <Card
            tag={s.tag}
            title={s.title}
            description={s.description}
            href={s.href}
            highlight={s.highlight}
          >
            <svg slot="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/>
            </svg>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════════
       STATS
  ═══════════════════════════════════════════════════════════════ -->
  <section class="section stats-section">
    <div class="container">
      <div class="stats-row reveal">
        <StatTile
          stat="15+"
          label="Hours saved per partner, per month"
          subtext="Across billing, reporting & intake"
        />
        <StatTile
          stat="<60s"
          label="Text-back for missed leads"
          subtext="Twilio-powered, always on"
        />
        <StatTile
          stat="2–4 hrs"
          label="Per client saved on month-end reports"
          subtext="Auto-generated after QBO close"
        />
        <StatTile
          stat="14 days"
          label="Average time to go live"
          subtext="From kickoff to production"
        />
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════════
       TWO AUDIENCES
  ═══════════════════════════════════════════════════════════════ -->
  <section class="section audience-section">
    <div class="container">
      <div class="section-header reveal">
        <h2>Built for two kinds of firms</h2>
      </div>
      <div class="audience-grid reveal-stagger">
        <div class="audience-card">
          <p class="audience-label">CPA &amp; Accounting Firms</p>
          <h3>2–10 partners,<br/>drowning in admin</h3>
          <ul class="audience-list">
            <li>Practice KPI Dashboard + WIP tracking</li>
            <li>Automated monthly client reports</li>
            <li>AI document intake for tax season</li>
            <li>Engagement → onboarding flow</li>
          </ul>
          <Button variant="primary" size="md" magnetic ripple data-open-booking>
            Talk to us
          </Button>
        </div>
        <div class="audience-card audience-card--alt">
          <p class="audience-label">Fractional CFO Practices</p>
          <h3>High-touch service,<br/>systematic delivery</h3>
          <ul class="audience-list">
            <li>Monthly snapshot per client — auto-delivered</li>
            <li>Onboarding flow: signed → active in hours</li>
            <li>Missed-lead text-back for inbound referrals</li>
            <li>QBO → reporting stack automation</li>
          </ul>
          <Button variant="secondary" size="md" magnetic ripple data-open-booking>
            Talk to us
          </Button>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════════
       PARTNERS
  ═══════════════════════════════════════════════════════════════ -->
  <section class="section partner-section">
    <div class="container">
      <p class="partner-eyebrow">Part of a trusted partner network</p>
      <div class="partner-band reveal">
        <a href="https://nexairi.com" class="partner-item" target="_blank" rel="noopener noreferrer">
          <span class="partner-name">Nexairi</span>
          <span class="partner-desc">AI news for accounting &amp; finance professionals</span>
        </a>
        <div class="partner-sep" aria-hidden="true"></div>
        <a href="https://simplysmart-consulting.com" class="partner-item" target="_blank" rel="noopener noreferrer">
          <span class="partner-name">Simply Smart Consulting</span>
          <span class="partner-desc">CPA-led bookkeeping &amp; fractional CFO services</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════════
       TESTIMONIALS
  ═══════════════════════════════════════════════════════════════ -->
  <section class="section">
    <div class="container">
      <div class="section-header reveal">
        <h2>What our clients say</h2>
      </div>
      <div class="testimonials-grid reveal-stagger">
        {[
          {
            quote:
              "We were spending 3 hours every month pulling the same data for each client. Now it runs overnight and shows up in my inbox before I've had coffee.",
            name: 'Managing Partner',
            firm: 'Regional CPA Firm',
          },
          {
            quote:
              "The onboarding flow was the unlock for us. A signed engagement letter used to mean 45 minutes of setup work. Now it's a Calendly link and a job in Karbon — automatically.",
            name: 'Fractional CFO',
            firm: 'Independent Practice',
          },
          {
            quote:
              "We were losing referrals because we couldn't respond fast enough. The text-back paid for itself in the first week when it caught a lead we would have missed completely.",
            name: 'Partner',
            firm: 'Small Accounting Firm',
          },
        ].map(({ quote, name, firm }) => (
          <blockquote class="testimonial">
            <p class="testimonial-quote">"{quote}"</p>
            <footer class="testimonial-author">
              <span class="testimonial-name">{name}</span>
              <span class="testimonial-firm">{firm}</span>
            </footer>
          </blockquote>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════════
       FAQ
  ═══════════════════════════════════════════════════════════════ -->
  <section class="section" id="faq">
    <div class="container faq-container">
      <div class="section-header reveal">
        <h2>Frequently asked questions</h2>
      </div>
      <div class="reveal">
        <Faq items={faqs} includeLdJson />
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════════
       FINAL CTA
  ═══════════════════════════════════════════════════════════════ -->
  <section class="section cta-final">
    <div class="container cta-final-inner reveal">
      <h2>Ready to automate your practice?</h2>
      <p>
        20-minute fit call. No sales pitch — just a clear scope of what we'd automate
        and what it would cost you to do it manually.
      </p>
      <Button variant="primary" size="lg" magnetic ripple data-open-booking>
        Book a fit call — it's free
      </Button>
      <p class="cta-contact">
        Prefer email?&nbsp;
        <a href="mailto:nick@5cypress.com">nick@5cypress.com</a>
      </p>
    </div>
  </section>
</Layout>

<style>
  /* ── Hero ─────────────────────────────────────────────────── */
  .hero {
    padding-block: var(--space-24) var(--space-20);
    overflow: hidden;
  }
  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-16);
    align-items: center;
  }
  .hero-copy { display: flex; flex-direction: column; gap: var(--space-6); }

  .hero-sub {
    font-size: var(--text-lg);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    max-width: 52ch;
  }

  .hero-ctas { display: flex; gap: var(--space-4); flex-wrap: wrap; }

  .hero-proof {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-tertiary);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
  }
  .hero-proof .sep { color: var(--border-medium); }

  .hero-visual {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    position: relative;
  }
  .hero-visual-glow {
    position: absolute;
    inset: -30%;
    background: radial-gradient(ellipse at center, rgba(93,140,93,0.12) 0%, transparent 70%);
    pointer-events: none;
    z-index: -1;
  }

  /* ── Pain points ──────────────────────────────────────────── */
  .pain-section { background: var(--bg-surface); }
  .pain-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-6);
    margin-top: var(--space-10);
  }
  .pain-item {
    display: flex;
    gap: var(--space-5);
    align-items: flex-start;
    padding: var(--space-6);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    background: var(--bg-main);
  }
  .pain-num {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    color: var(--brand-primary);
    letter-spacing: var(--tracking-widest);
    flex-shrink: 0;
    padding-top: 2px;
  }
  .pain-text {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
  }

  /* ── Section header ───────────────────────────────────────── */
  .section-header {
    max-width: 60ch;
    margin-bottom: var(--space-12);
  }
  .section-sub {
    margin-top: var(--space-4);
    font-size: var(--text-base);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
  }

  /* ── Services grid ────────────────────────────────────────── */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
  }
  .services-grid > :last-child:nth-child(3n - 1) {
    grid-column: span 1;
  }

  /* ── Stats ────────────────────────────────────────────────── */
  .stats-section { border-block: 1px solid var(--border-subtle); }
  .stats-row {
    display: flex;
    flex-wrap: wrap;
  }

  /* ── Audience ─────────────────────────────────────────────── */
  .audience-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-6);
  }
  .audience-card {
    background: var(--bg-surface);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-xl);
    padding: var(--space-10);
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }
  .audience-card--alt {
    border-color: rgba(93,140,93,0.2);
    background: linear-gradient(135deg, var(--bg-surface) 0%, rgba(93,140,93,0.04) 100%);
  }
  .audience-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--brand-primary);
  }
  .audience-card h3 {
    font-size: var(--text-2xl);
    line-height: var(--leading-snug);
  }
  .audience-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    flex: 1;
  }
  .audience-list li {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    font-size: var(--text-sm);
    color: var(--text-secondary);
  }
  .audience-list li::before {
    content: '→';
    color: var(--brand-primary);
    font-family: var(--font-mono);
    flex-shrink: 0;
  }

  /* ── Partners ─────────────────────────────────────────────── */
  .partner-eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-disabled);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    text-align: center;
    margin-bottom: var(--space-8);
  }
  .partner-band {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-10);
    flex-wrap: wrap;
    padding: var(--space-8);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-xl);
    background: var(--bg-surface);
  }
  .partner-sep {
    width: 1px;
    height: 40px;
    background: var(--border-subtle);
  }
  .partner-item {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    text-decoration: none;
    text-align: center;
    transition: opacity var(--duration-fast);
  }
  .partner-item:hover { opacity: 0.8; }
  .partner-name {
    font-family: var(--font-heading);
    font-weight: var(--weight-bold);
    font-size: var(--text-base);
    color: var(--text-primary);
  }
  .partner-desc {
    font-size: var(--text-xs);
    color: var(--text-tertiary);
  }

  /* ── Testimonials ─────────────────────────────────────────── */
  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
  }
  .testimonial {
    background: var(--bg-surface);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-xl);
    padding: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }
  .testimonial-quote {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    font-style: italic;
    flex: 1;
  }
  .testimonial-author { display: flex; flex-direction: column; gap: var(--space-1); }
  .testimonial-name {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--text-primary);
  }
  .testimonial-firm {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-tertiary);
  }

  /* ── FAQ ──────────────────────────────────────────────────── */
  .faq-container { max-width: 760px; }

  /* ── Final CTA ────────────────────────────────────────────── */
  .cta-final {
    background: var(--bg-surface);
    border-top: 1px solid var(--border-subtle);
  }
  .cta-final-inner {
    max-width: 640px;
    margin-inline: auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-6);
  }
  .cta-final h2 { font-size: var(--text-4xl); }
  .cta-final p {
    color: var(--text-secondary);
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    max-width: 48ch;
  }
  .cta-contact { font-size: var(--text-sm); color: var(--text-tertiary); }
  .cta-contact a { color: var(--brand-primary); text-decoration: none; }
  .cta-contact a:hover { text-decoration: underline; }

  /* ── Responsive ───────────────────────────────────────────── */
  @media (max-width: 1024px) {
    .services-grid { grid-template-columns: repeat(2, 1fr); }
    .testimonials-grid { grid-template-columns: 1fr 1fr; }
  }

  @media (max-width: 768px) {
    .hero-inner {
      grid-template-columns: 1fr;
      gap: var(--space-12);
    }
    .hero-visual { justify-content: center; }
    .pain-grid { grid-template-columns: 1fr; }
    .services-grid { grid-template-columns: 1fr; }
    .audience-grid { grid-template-columns: 1fr; }
    .testimonials-grid { grid-template-columns: 1fr; }
    .stats-row { flex-direction: column; }
    .partner-sep { display: none; }
  }
</style>
