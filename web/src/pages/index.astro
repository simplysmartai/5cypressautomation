---
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';
import Card from '../components/Card.astro';
import StatTile from '../components/StatTile.astro';
import Faq from '../components/Faq.astro';
import JsonLd from '../components/JsonLd.astro';

const coreWorkflows = [
  {
    tag: '01 / Capture',
    title: 'Lead capture and follow-up',
    description:
      'When a form, missed call, referral, or ad lead comes in, the system replies fast, creates the record, alerts the owner, and keeps the next step visible.',
    href: '/services/missed-lead-text-back/',
    highlight: true,
  },
  {
    tag: '02 / Report',
    title: 'Dashboards and KPI reporting',
    description:
      'Pull the numbers out of exports and inboxes. Build dashboards and scheduled reports people can use before the decision window closes.',
    href: '/services/business-intelligence-dashboard/',
  },
  {
    tag: '03 / Route',
    title: 'Document intake and routing',
    description:
      'Collect files, classify what they are, rename them, and route exceptions to a person instead of letting folders become a second job.',
    href: '/services/document-intake-ai-sort/',
  },
  {
    tag: '04 / Collect',
    title: 'Billing and payment workflows',
    description:
      'Connect proposals, invoices, reminders, payment links, QBO records, and review steps so money does not depend on memory.',
    href: '/services/ar-collections-agent/',
  },
  {
    tag: '05 / Start',
    title: 'Client and customer onboarding',
    description:
      'Turn a signed agreement or new order into kickoff tasks, folders, calendar links, CRM updates, and internal notifications.',
    href: '/services/engagement-onboarding-flow/',
    highlight: true,
  },
];

const operatingScenes = [
  {
    title: 'The lead comes in after hours',
    text: 'The reply goes out, the contact is logged, the service need is tagged, and the right person sees the next step before the morning inbox pileup starts.',
  },
  {
    title: 'The report used to take Friday afternoon',
    text: 'The numbers refresh from the source systems, exceptions are flagged, and the summary is ready for review instead of being rebuilt from exports.',
  },
  {
    title: 'The file drop is no longer a mystery box',
    text: 'Documents are named, sorted, routed, and queued for human review when the system is not confident enough to act alone.',
  },
];

const sectors = [
  {
    label: 'Accounting and finance',
    text: 'QBO workflows, client reporting, document intake, AR, close support, KPI dashboards, and onboarding.',
  },
  {
    label: 'Service businesses',
    text: 'Lead follow-up, scheduling, proposal handoffs, invoice reminders, operations dashboards, and client updates.',
  },
  {
    label: 'Medical and professional offices',
    text: 'Inbound requests, document routing, appointment workflows, referral tracking, and staff task automation.',
  },
  {
    label: 'Custom workflow builds',
    text: 'The recurring task that is too specific for off-the-shelf software and too expensive to keep doing by hand.',
  },
];

const trustSignals = [
  {
    title: 'Scope before build',
    text: 'You get a workflow map, systems list, handoff points, and rough timeline before the build starts.',
  },
  {
    title: 'Test data first',
    text: 'Production data waits until triggers, validation, exceptions, and review points are clear.',
  },
  {
    title: 'No new platform by default',
    text: 'The first move is usually connecting the tools already in the business, not adding another login.',
  },
  {
    title: 'Documented handoff',
    text: 'Each workflow ships with plain-English notes so the team knows what runs, what to check, and who owns it.',
  },
];

const demoWorkflows = [
  {
    label: 'Lead flow',
    title: 'Referral lead captured and routed',
    metric: '47 sec',
    metricLabel: 'first response',
    status: 'Owner alerted',
    rows: [
      ['Source', 'Website form'],
      ['Record', 'CRM contact created'],
      ['Need', 'Automation scoping'],
      ['Next step', 'Send calendar link'],
    ],
    timeline: ['Form received', 'CRM checked', 'Reply sent', 'Task assigned'],
  },
  {
    label: 'Invoice flow',
    title: 'Aging invoice escalated cleanly',
    metric: '$18,420',
    metricLabel: 'at-risk AR',
    status: 'Review queued',
    rows: [
      ['System', 'QuickBooks Online'],
      ['Aging', '45 days'],
      ['Tone', 'Warm reminder'],
      ['Next step', 'Partner review if unpaid'],
    ],
    timeline: ['QBO sync', 'Rule matched', 'Reminder drafted', 'Promise tracked'],
  },
  {
    label: 'Document flow',
    title: 'Client files sorted automatically',
    metric: '38',
    metricLabel: 'files routed',
    status: '2 exceptions',
    rows: [
      ['Batch', 'May close packet'],
      ['Detected', 'Statements / receipts'],
      ['Destination', 'Client folder'],
      ['Exception', 'Needs review'],
    ],
    timeline: ['Upload received', 'Files classified', 'Names standardized', 'Exceptions queued'],
  },
];

const nextSteps = [
  'You describe the workflow that keeps slowing the team down.',
  'We map the handoffs, systems, review points, and first useful build.',
  'You decide whether to scope it. No pitch deck, no pressure.',
];

const faqs = [
  {
    question: 'Do you only work with accounting and finance firms?',
    answer:
      'No. Accounting and finance are a strong specialty because those teams have heavy reporting, billing, document, and onboarding workflows. The same automation patterns also apply to service businesses, medical offices, agencies, operations teams, and other small B2B companies.',
  },
  {
    question: 'What does the "5" in 5 Cypress mean?',
    answer:
      'It gives the brand a practical operating model: five ready-to-build workflow systems most companies need. Each one can be installed as a focused automation or adapted into a custom workflow for a specific business.',
  },
  {
    question: 'Are these AI tools or normal automations?',
    answer:
      'Both, when useful. Some workflows only need clean rules and reliable API connections. Others benefit from AI for classification, summarization, routing, or drafting. The goal is not to add AI everywhere; it is to remove the work safely.',
  },
  {
    question: 'How fast can a project go live?',
    answer:
      'Focused workflows often go live in 5-14 business days. Multi-system builds usually take 3-4 weeks because the edge cases, approvals, and testing matter.',
  },
  {
    question: 'What happens after launch?',
    answer:
      'You get documentation and a handoff. For clients who want ongoing help, we monitor, adjust, and expand workflows as tools, teams, and business rules change.',
  },
];

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: '5 Cypress Automation',
  url: 'https://www.5cypress.com',
  logo: 'https://www.5cypress.com/assets/brand/5cypress-mark.svg',
  email: 'nick@5cypress.com',
  description:
    'Business automation systems for small B2B teams, including lead capture, reporting dashboards, document intake, billing workflows, and onboarding automation.',
  sameAs: [],
};

const serviceSchemas = coreWorkflows.map((s) => ({
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'Business Automation',
  name: s.title,
  description: s.description,
  provider: {
    '@type': 'Organization',
    name: '5 Cypress Automation',
    url: 'https://www.5cypress.com',
  },
  areaServed: { '@type': 'Country', name: 'United States' },
}));
---

<Layout
  title="Workflow Automation Systems | 5 Cypress Automation"
  description="5 Cypress Automation maps and builds practical workflow systems for growing B2B teams: lead follow-up, dashboards, document intake, billing, and onboarding."
>
  <Fragment slot="head">
    <JsonLd schema={orgSchema} />
    <JsonLd schema={serviceSchemas} />
  </Fragment>

  <section class="hero section">
    <div class="container hero-inner">
      <div class="hero-copy reveal">
        <p class="lead-in">Founder-led workflow automation</p>
        <h1>Your team is not slow. The handoffs are.</h1>
        <p class="hero-sub">
          5 Cypress maps the manual steps hiding between your forms, inboxes, spreadsheets,
          CRMs, QuickBooks files, folders, and reports. Then we build the first workflow that
          removes the drag without turning your business into an AI science project.
        </p>
        <div class="hero-ctas">
          <Button variant="primary" size="lg" magnetic ripple data-open-booking>
            Map My Workflow
          </Button>
          <Button variant="secondary" size="lg" href="/services/">
            See the 5 systems
          </Button>
        </div>
        <div class="hero-proof" aria-label="5 Cypress operating principles">
          <span>Map first</span>
          <span>Build narrow</span>
          <span>Test with real edge cases</span>
          <span>Document the handoff</span>
        </div>
      </div>

      <div class="hero-visual reveal" aria-label="Workflow control room preview">
        <div class="control-room">
          <div class="control-room-top">
            <div>
              <span class="panel-kicker">Live workflow map</span>
              <h2>Intake to action</h2>
            </div>
            <span class="system-status">Human review on</span>
          </div>

          <div class="route-map" aria-hidden="true">
            <div class="route-node route-node--active">
              <span>01</span>
              <strong>Lead captured</strong>
              <small>Form / call / referral</small>
            </div>
            <div class="route-line"></div>
            <div class="route-node">
              <span>02</span>
              <strong>Record checked</strong>
              <small>CRM + duplicate rules</small>
            </div>
            <div class="route-line"></div>
            <div class="route-node">
              <span>03</span>
              <strong>Owner alerted</strong>
              <small>SMS + inbox + task</small>
            </div>
          </div>

          <div class="signal-grid">
            <div class="signal-card">
              <span>First response</span>
              <strong>47 sec</strong>
              <small>inside business rule</small>
            </div>
            <div class="signal-card">
              <span>Open exceptions</span>
              <strong>2</strong>
              <small>needs review</small>
            </div>
            <div class="signal-card signal-card--gold">
              <span>Manual steps removed</span>
              <strong>6</strong>
              <small>from intake flow</small>
            </div>
          </div>

          <div class="system-log">
            <div><span>15:42</span><p>New lead matched automation services</p></div>
            <div><span>15:42</span><p>CRM record created with source tag</p></div>
            <div><span>15:43</span><p>Owner notified; calendar link queued</p></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section scene-section">
    <div class="container">
      <div class="section-header reveal">
        <p class="lead-in">Where the work leaks</p>
        <h2>The problem is usually not the tool. It is the space between tools.</h2>
      </div>
      <div class="scene-grid reveal-stagger">
        {operatingScenes.map((scene) => (
          <article class="scene-card">
            <h3>{scene.title}</h3>
            <p>{scene.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section workflow-section" id="workflows">
    <div class="container">
      <div class="section-header reveal">
        <p class="lead-in">The 5 Cypress model</p>
        <h2>Five workflow systems. Built like starting points, not templates.</h2>
        <p class="section-sub">
          Most companies do not need a giant transformation project. They need one broken
          handoff fixed well enough that the team trusts it. These five systems are where
          that first win usually lives.
        </p>
      </div>
      <div class="services-grid reveal-stagger">
        {coreWorkflows.map((s) => (
          <Card
            tag={s.tag}
            title={s.title}
            description={s.description}
            href={s.href}
            highlight={s.highlight}
          >
            <svg slot="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 7h7m-7 5h12m-12 5h16M16 5l4 2-4 2M13 10l4 2-4 2M18 15l3 2-3 2"/>
            </svg>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <section class="section stats-section">
    <div class="container">
      <div class="stats-intro reveal">
        <p class="lead-in">Scope with restraint</p>
        <h2>Premium work is not bigger. It is clearer.</h2>
      </div>
      <div class="stats-row reveal">
        <StatTile stat="5-14" label="Business days for focused workflow builds" subtext="Lead follow-up, routing, reporting, reminders" />
        <StatTile stat="3-4" label="Weeks for multi-system automations" subtext="When approvals, edge cases, and testing matter" />
        <StatTile stat="0" label="New platform required by default" subtext="We connect the tools already in the business" />
        <StatTile stat="1" label="Plain-English runbook after launch" subtext="So the workflow is understandable, not mysterious" />
      </div>
    </div>
  </section>

  <section class="section sectors-section">
    <div class="container sectors-layout">
      <div class="section-header reveal">
        <p class="lead-in">Specialized, not boxed in</p>
        <h2>Accounting and finance proves the depth. The workflow logic travels.</h2>
        <p class="section-sub">
          Dense financial workflows make a strong proving ground: QuickBooks data, document intake,
          approvals, reports, invoices, and client updates. But the same handoff problems show up
          in any serious B2B operation.
        </p>
      </div>
      <div class="sector-grid reveal-stagger">
        {sectors.map((sector) => (
          <article class="sector-card">
            <h3>{sector.label}</h3>
            <p>{sector.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section trust-section">
    <div class="container">
      <div class="trust-grid">
        <div class="trust-copy reveal">
          <p class="lead-in">How trust is built</p>
          <h2>Useful automation should feel controlled, not mysterious.</h2>
          <p>
            The safest workflows are boring in the right places: clear triggers,
            validated data, visible exceptions, and a documented handoff. That is
            how 5 Cypress keeps automation practical instead of fragile.
          </p>
        </div>

        <div class="trust-list reveal-stagger">
          {trustSignals.map((signal) => (
            <article class="trust-card">
              <h3>{signal.title}</h3>
              <p>{signal.text}</p>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section demo-section">
    <div class="container">
      <div class="demo-header reveal">
        <p class="lead-in">Dummy workflow data</p>
        <h2>This is the kind of visibility automation should create.</h2>
        <p>
          These are sample records, not client claims. They show the shape of a useful workflow:
          what came in, what changed, what still needs a human, and who owns the next step.
        </p>
      </div>
      <div class="demo-grid reveal-stagger">
        {demoWorkflows.map((demo) => (
          <article class="workflow-demo">
            <div class="workflow-demo-top">
              <span class="workflow-demo-label">{demo.label}</span>
              <span class="workflow-demo-live">{demo.status}</span>
            </div>
            <h3>{demo.title}</h3>
            <div class="workflow-demo-metric">
              <span>{demo.metric}</span>
              <p>{demo.metricLabel}</p>
            </div>
            <div class="workflow-demo-rows">
              {demo.rows.map(([key, value]) => (
                <div class="workflow-demo-row">
                  <span>{key}</span>
                  <strong>{value}</strong>
                </div>
              ))}
            </div>
            <div class="workflow-timeline">
              {demo.timeline.map((step, index) => (
                <div class="workflow-step">
                  <span>{String(index + 1).padStart(2, '0')}</span>
                  <p>{step}</p>
                </div>
              ))}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section" id="faq">
    <div class="container faq-container">
      <div class="section-header reveal">
        <p class="lead-in">Buyer questions</p>
        <h2>What people usually ask before they trust an automation build</h2>
      </div>
      <div class="reveal">
        <Faq items={faqs} includeLdJson />
      </div>
    </div>
  </section>

  <section class="section cta-final">
    <div class="container cta-final-inner reveal">
      <p class="lead-in">Start narrow</p>
      <h2>Bring the workflow your team keeps working around.</h2>
      <p>
        In one mapping session, we can usually tell whether the work should be automated,
        simplified, delegated, or left alone.
      </p>
      <div class="next-steps" aria-label="What happens next">
        {nextSteps.map((step, index) => (
          <div class="next-step">
            <span>{String(index + 1).padStart(2, '0')}</span>
            <p>{step}</p>
          </div>
        ))}
      </div>
      <Button variant="primary" size="lg" magnetic ripple data-open-booking>
        Map My Workflow
      </Button>
      <p class="cta-contact">
        Prefer email?
        <a href="mailto:nick@5cypress.com">nick@5cypress.com</a>
      </p>
    </div>
  </section>
</Layout>

<style>
  .hero {
    min-height: 92vh;
    display: flex;
    align-items: center;
    padding-block: var(--space-32) var(--space-20);
    overflow: hidden;
    position: relative;
  }
  .hero::before {
    content: '';
    position: absolute;
    inset: 96px var(--space-6) auto;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(251,191,36,0.28), rgba(93,140,93,0.28), transparent);
  }
  .hero-inner {
    display: grid;
    grid-template-columns: minmax(0, 0.92fr) minmax(420px, 0.88fr);
    gap: var(--space-16);
    align-items: center;
  }
  .hero-copy {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }
  .hero h1 {
    max-width: 10ch;
    font-size: clamp(3.25rem, 7.6vw, 6.65rem);
    letter-spacing: 0;
  }
  .hero-sub {
    font-size: clamp(1.05rem, 1.7vw, 1.25rem);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    max-width: 64ch;
  }
  .hero-ctas {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
  }
  .hero-proof {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: var(--space-2);
    max-width: 720px;
  }
  .hero-proof span {
    min-height: 72px;
    display: flex;
    align-items: end;
    padding: var(--space-3);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
    background: rgba(20,20,24,0.58);
    color: var(--text-tertiary);
    font-family: var(--font-mono);
    font-size: 0.66rem;
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-widest);
    line-height: var(--leading-snug);
    text-transform: uppercase;
  }
  .hero-visual {
    position: relative;
  }
  .control-room {
    position: relative;
    min-height: 620px;
    padding: var(--space-6);
    border: 1px solid var(--border-medium);
    border-radius: 28px;
    background:
      linear-gradient(180deg, rgba(93,140,93,0.13), transparent 32%),
      radial-gradient(circle at 90% 0%, rgba(251,191,36,0.16), transparent 34%),
      #101014;
    box-shadow: 0 50px 120px rgba(0,0,0,0.62);
    overflow: hidden;
  }
  .control-room::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.04) 1px, transparent 1px);
    background-size: 32px 32px;
    mask-image: linear-gradient(to bottom, black, transparent 78%);
    pointer-events: none;
  }
  .control-room > * {
    position: relative;
    z-index: 1;
  }
  .control-room-top {
    display: flex;
    justify-content: space-between;
    gap: var(--space-6);
    align-items: start;
    margin-bottom: var(--space-8);
  }
  .panel-kicker,
  .system-status {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
  }
  .panel-kicker { color: var(--brand-primary-light); }
  .control-room h2 {
    margin-top: var(--space-2);
    font-size: var(--text-3xl);
  }
  .system-status {
    white-space: nowrap;
    color: var(--brand-accent);
    padding: 7px 10px;
    border: 1px solid rgba(251,191,36,0.24);
    border-radius: var(--radius-full);
    background: rgba(251,191,36,0.08);
  }
  .route-map {
    display: grid;
    grid-template-columns: 1fr 48px 1fr 48px 1fr;
    gap: var(--space-3);
    align-items: center;
  }
  .route-node {
    min-height: 154px;
    padding: var(--space-4);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    background: rgba(10,10,12,0.76);
  }
  .route-node--active {
    border-color: rgba(251,191,36,0.32);
    box-shadow: inset 0 0 0 1px rgba(251,191,36,0.08);
  }
  .route-node span {
    display: block;
    margin-bottom: var(--space-8);
    color: var(--brand-accent);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
  }
  .route-node strong {
    display: block;
    color: var(--text-primary);
    font-family: var(--font-heading);
    font-size: var(--text-base);
  }
  .route-node small {
    display: block;
    margin-top: var(--space-2);
    color: var(--text-disabled);
    line-height: var(--leading-normal);
  }
  .route-line {
    height: 1px;
    background: linear-gradient(90deg, var(--brand-primary), var(--brand-accent));
    position: relative;
  }
  .route-line::after {
    content: '';
    position: absolute;
    right: 0;
    top: 50%;
    width: 8px;
    height: 8px;
    border-top: 1px solid var(--brand-accent);
    border-right: 1px solid var(--brand-accent);
    transform: translateY(-50%) rotate(45deg);
  }
  .signal-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-3);
    margin-top: var(--space-6);
  }
  .signal-card {
    min-height: 136px;
    padding: var(--space-4);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    background: var(--bg-main);
  }
  .signal-card span,
  .signal-card small {
    color: var(--text-disabled);
    font-size: var(--text-xs);
  }
  .signal-card strong {
    display: block;
    margin-block: var(--space-3) var(--space-2);
    color: var(--text-primary);
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    line-height: 1;
  }
  .signal-card--gold strong { color: var(--brand-accent); }
  .system-log {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-top: var(--space-6);
  }
  .system-log div {
    display: grid;
    grid-template-columns: 64px 1fr;
    gap: var(--space-4);
    padding: var(--space-3);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
    background: rgba(10,10,12,0.62);
  }
  .system-log span {
    color: var(--brand-primary-light);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
  }
  .system-log p {
    color: var(--text-secondary);
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
  }

  .section-header {
    max-width: 78ch;
    margin-bottom: var(--space-12);
  }
  .section-sub {
    margin-top: var(--space-4);
    font-size: var(--text-base);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
  }
  .scene-section {
    border-block: 1px solid var(--border-subtle);
