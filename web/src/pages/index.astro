---
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';
import Card from '../components/Card.astro';
import StatTile from '../components/StatTile.astro';
import Faq from '../components/Faq.astro';
import MicroDashboard from '../components/MicroDashboard.astro';
import JsonLd from '../components/JsonLd.astro';

const coreWorkflows = [
  {
    tag: '01 / Leads',
    title: 'Lead capture and follow-up',
    description:
      'Route form fills, missed calls, referrals, and ad leads into one system with fast replies, owner alerts, and clean CRM records.',
    href: '/services/missed-lead-text-back/',
    highlight: true,
  },
  {
    tag: '02 / Reporting',
    title: 'Dashboards and KPI reporting',
    description:
      'Turn scattered exports into live dashboards, scheduled reports, and decision-ready summaries your team can trust.',
    href: '/services/business-intelligence-dashboard/',
  },
  {
    tag: '03 / Intake',
    title: 'Document intake and routing',
    description:
      'Collect files, classify documents, rename them, and send them to the right folder, job, client, or person automatically.',
    href: '/services/document-intake-ai-sort/',
  },
  {
    tag: '04 / Money',
    title: 'Billing, invoice, and payment flows',
    description:
      'Connect proposals, invoices, reminders, payment links, bookkeeping records, and status updates without manual re-entry.',
    href: '/services/ar-collections-agent/',
  },
  {
    tag: '05 / Onboarding',
    title: 'Client and customer onboarding',
    description:
      'Move a signed agreement or new order into kickoff tasks, calendar links, records, folders, and internal notifications.',
    href: '/services/engagement-onboarding-flow/',
    highlight: true,
  },
];

const sectors = [
  {
    label: 'Accounting and finance',
    text: 'QBO workflows, client reporting, document intake, AR, close support, KPI dashboards, and onboarding.',
  },
  {
    label: 'Service businesses',
    text: 'Lead follow-up, scheduling, proposal handoffs, invoice reminders, operations dashboards, and client updates.',
  },
  {
    label: 'Medical and professional offices',
    text: 'Inbound requests, document routing, appointment workflows, referral tracking, and staff task automation.',
  },
  {
    label: 'Custom one-off builds',
    text: 'The recurring workflow that is too specific for off-the-shelf software but too expensive to keep doing by hand.',
  },
];

const trustSignals = [
  {
    title: 'Scope before build',
    text: 'You get a clear workflow map, systems list, handoff points, and rough timeline before anything is built.',
  },
  {
    title: 'Test data first',
    text: 'Production data comes after the trigger, validation, exception path, and human review points are clear.',
  },
  {
    title: 'No new platform by default',
    text: 'The first choice is usually to connect the tools already in the business, not force another login.',
  },
  {
    title: 'Documented handoff',
    text: 'Each workflow ships with plain-English notes so the team knows what it does and what to check.',
  },
];

const nextSteps = [
  'You describe the workflow that keeps slowing the team down.',
  'We identify the first useful build and what systems it touches.',
  'You decide whether to scope it. No pitch deck, no pressure.',
];

const demoWorkflows = [
  {
    label: 'Lead flow',
    title: 'Referral lead captured and routed',
    metric: '47 sec',
    metricLabel: 'first response',
    rows: [
      ['Source', 'Website form'],
      ['Owner', 'Nick / Sales'],
      ['Status', 'Fit call requested'],
      ['Next step', 'Send calendar link'],
    ],
    timeline: ['Form received', 'CRM record created', 'SMS sent', 'Owner notified'],
  },
  {
    label: 'Invoice flow',
    title: 'Aging invoice escalated cleanly',
    metric: '$18,420',
    metricLabel: 'at-risk AR',
    rows: [
      ['Client', 'Crescent Supply Co.'],
      ['Aging', '45 days'],
      ['Tone', 'Warm reminder'],
      ['Next step', 'Partner review if unpaid'],
    ],
    timeline: ['QBO sync', 'Aging rule matched', 'Reminder drafted', 'Promise-to-pay tracked'],
  },
  {
    label: 'Document flow',
    title: 'Client files sorted automatically',
    metric: '38',
    metricLabel: 'files routed',
    rows: [
      ['Batch', 'May close packet'],
      ['Detected', 'Statements / receipts'],
      ['Destination', 'Client folder'],
      ['Exception', '2 need review'],
    ],
    timeline: ['Upload received', 'Files classified', 'Names standardized', 'Exceptions queued'],
  },
];

const faqs = [
  {
    question: 'Do you only work with accounting and finance firms?',
    answer:
      'No. Accounting and finance are a strong specialty because those teams have heavy reporting, billing, document, and onboarding workflows. The same automation patterns also apply to service businesses, medical offices, agencies, operations teams, and other small B2B companies.',
  },
  {
    question: 'What does the "5" in 5 Cypress mean?',
    answer:
      'It gives the brand a practical operating model: five ready-to-build workflow systems most companies need. Each one can be installed as a focused automation or adapted into a custom workflow for a specific business.',
  },
  {
    question: 'Are these AI tools or normal automations?',
    answer:
      'Both, when useful. Some workflows only need clean rules and reliable API connections. Others benefit from AI for classification, summarization, routing, or drafting. The goal is not to add AI everywhere; it is to remove the work safely.',
  },
  {
    question: 'How fast can a project go live?',
    answer:
      'Focused workflows often go live in 5-14 business days. Multi-system builds usually take 3-4 weeks because the edge cases, approvals, and testing matter.',
  },
  {
    question: 'What happens after launch?',
    answer:
      'You get documentation and a handoff. For clients who want ongoing help, we monitor, adjust, and expand workflows as tools, teams, and business rules change.',
  },
];

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: '5 Cypress Automation',
  url: 'https://www.5cypress.com',
  logo: 'https://www.5cypress.com/assets/brand/5cypress-mark.svg',
  email: 'nick@5cypress.com',
  description:
    'Business automation systems for small B2B teams, including lead capture, reporting dashboards, document intake, billing workflows, and onboarding automation.',
  sameAs: [],
};

const serviceSchemas = coreWorkflows.map((s) => ({
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'Business Automation',
  name: s.title,
  description: s.description,
  provider: {
    '@type': 'Organization',
    name: '5 Cypress Automation',
    url: 'https://www.5cypress.com',
  },
  areaServed: { '@type': 'Country', name: 'United States' },
}));
---

<Layout
  title="Business Automation Systems | 5 Cypress Automation"
  description="5 Cypress Automation builds practical workflows for growing teams: lead follow-up, dashboards, document intake, billing, and onboarding."
>
  <Fragment slot="head">
    <JsonLd schema={orgSchema} />
    <JsonLd schema={serviceSchemas} />
  </Fragment>

  <section class="hero section">
    <div class="container hero-inner">
      <div class="hero-copy reveal">
        <p class="lead-in">Workflow systems for growing teams</p>
        <h1>Automation that feels built into your business.</h1>
        <p class="hero-sub">
          5 Cypress builds practical automation workflows that connect the tools you already use,
          remove repeat manual work, and give your team cleaner data without forcing a new platform.
        </p>
        <div class="hero-ctas">
          <Button variant="primary" size="lg" magnetic ripple data-open-booking>
            Book a Workflow Call
          </Button>
          <Button variant="secondary" size="lg" href="/services/">
            Explore the 5 workflows
          </Button>
        </div>
        <p class="hero-proof">
          <span>5 ready-to-build systems</span>
          <span class="sep">/</span>
          <span>customized to your stack</span>
          <span class="sep">/</span>
          <span>Cloudflare-first site</span>
        </p>
      </div>

      <div class="hero-visual reveal">
        <MicroDashboard variant="practice-kpi" />
        <div class="hero-orbit hero-orbit--one" aria-hidden="true"></div>
        <div class="hero-orbit hero-orbit--two" aria-hidden="true"></div>
      </div>
    </div>
  </section>

  <section class="section workflow-section" id="workflows">
    <div class="container">
      <div class="section-header reveal">
        <p class="lead-in">The 5 Cypress model</p>
        <h2>Five workflow systems most companies need.</h2>
        <p class="section-sub">
          Start with a proven pattern, then tune it to the way your business actually runs.
          These are not generic templates; they are repeatable starting points.
        </p>
      </div>
      <div class="services-grid reveal-stagger">
        {coreWorkflows.map((s) => (
          <Card
            tag={s.tag}
            title={s.title}
            description={s.description}
            href={s.href}
            highlight={s.highlight}
          >
            <svg slot="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 7h7m-7 5h12m-12 5h16M16 5l4 2-4 2M13 10l4 2-4 2M18 15l3 2-3 2"/>
            </svg>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <section class="section stats-section">
    <div class="container">
      <div class="stats-row reveal">
        <StatTile
          stat="5-14"
          label="Business days for focused workflow builds"
          subtext="Lead follow-up, routing, reporting, reminders"
        />
        <StatTile
          stat="3-4"
          label="Weeks for multi-system automations"
          subtext="When approvals, edge cases, and testing matter"
        />
        <StatTile
          stat="0"
          label="New platform required by default"
          subtext="We connect the tools already in the business"
        />
        <StatTile
          stat="1"
          label="Clear runbook after launch"
          subtext="So the workflow is understandable, not mysterious"
        />
      </div>
    </div>
  </section>

  <section class="section sectors-section">
    <div class="container">
      <div class="section-header reveal">
        <p class="lead-in">Specialized, not boxed in</p>
        <h2>Strong in accounting and finance. Useful far beyond it.</h2>
        <p class="section-sub">
          The best automations are built around repeated handoffs: someone submits, someone reviews,
          something gets filed, a record changes, a report goes out. That pattern shows up in every serious business.
        </p>
      </div>
      <div class="sector-grid reveal-stagger">
        {sectors.map((sector) => (
          <div class="sector-card">
            <h3>{sector.label}</h3>
            <p>{sector.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section trust-section">
    <div class="container">
      <div class="trust-grid">
        <div class="trust-copy reveal">
          <p class="lead-in">Trust the build</p>
          <h2>Useful automation should feel controlled, not mysterious.</h2>
          <p>
            The safest workflows are boring in the right places: clear triggers,
            validated data, visible exceptions, and a documented handoff. That is
            how 5 Cypress keeps automation practical instead of fragile.
          </p>
        </div>

        <div class="trust-list reveal-stagger">
          {trustSignals.map((signal) => (
            <article class="trust-card">
              <h3>{signal.title}</h3>
              <p>{signal.text}</p>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section method-section">
    <div class="container method-grid">
      <div class="method-copy reveal">
        <p class="lead-in">How we build</p>
        <h2>Modern automation without the AI costume.</h2>
        <p>
          We use AI where it earns its place: reading documents, classifying requests,
          drafting summaries, finding exceptions, and turning raw data into useful language.
          The rest is disciplined workflow design, validation, logging, and clean handoff.
        </p>
      </div>
      <div class="method-list reveal-stagger">
        <div class="method-item">
          <span>01</span>
          <div>
            <h3>Map the handoff</h3>
            <p>What starts the workflow, who needs to know, and what can go wrong?</p>
          </div>
        </div>
        <div class="method-item">
          <span>02</span>
          <div>
            <h3>Connect the stack</h3>
            <p>APIs, forms, databases, email, SMS, dashboards, files, and existing tools.</p>
          </div>
        </div>
        <div class="method-item">
          <span>03</span>
          <div>
            <h3>Test the edge cases</h3>
            <p>Bad inputs, missing fields, duplicate records, retries, and human approvals.</p>
          </div>
        </div>
        <div class="method-item">
          <span>04</span>
          <div>
            <h3>Document the system</h3>
            <p>Your team gets a plain-English runbook and a workflow that can evolve.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section demo-section">
    <div class="container">
      <div class="demo-header reveal">
        <p class="lead-in">Sample workflow data</p>
        <h2>Make the invisible work visible.</h2>
        <p>
          These are dummy examples, but they show the kind of operational view a finished
          automation can give you: what happened, where it went, what needs attention, and who owns it.
        </p>
      </div>
      <div class="demo-grid reveal-stagger">
        {demoWorkflows.map((demo) => (
          <article class="workflow-demo">
            <div class="workflow-demo-top">
              <span class="workflow-demo-label">{demo.label}</span>
              <span class="workflow-demo-live">Demo data</span>
            </div>
            <h3>{demo.title}</h3>
            <div class="workflow-demo-metric">
              <span>{demo.metric}</span>
              <p>{demo.metricLabel}</p>
            </div>
            <div class="workflow-demo-rows">
              {demo.rows.map(([key, value]) => (
                <div class="workflow-demo-row">
                  <span>{key}</span>
                  <strong>{value}</strong>
                </div>
              ))}
            </div>
            <div class="workflow-timeline">
              {demo.timeline.map((step, index) => (
                <div class="workflow-step">
                  <span>{String(index + 1).padStart(2, '0')}</span>
                  <p>{step}</p>
                </div>
              ))}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section" id="faq">
    <div class="container faq-container">
      <div class="section-header reveal">
        <h2>Questions people usually ask</h2>
      </div>
      <div class="reveal">
        <Faq items={faqs} includeLdJson />
      </div>
    </div>
  </section>

  <section class="section cta-final">
    <div class="container cta-final-inner reveal">
      <h2>Bring the messy workflow.</h2>
      <p>
        In 20 minutes we can usually tell whether it should be automated, simplified,
        delegated, or left alone.
      </p>
      <div class="next-steps" aria-label="What happens next">
        {nextSteps.map((step, index) => (
          <div class="next-step">
            <span>{String(index + 1).padStart(2, '0')}</span>
            <p>{step}</p>
          </div>
        ))}
      </div>
      <Button variant="primary" size="lg" magnetic ripple data-open-booking>
        Book a Workflow Call
      </Button>
      <p class="cta-contact">
        Prefer email?
        <a href="mailto:nick@5cypress.com">nick@5cypress.com</a>
      </p>
    </div>
  </section>
</Layout>

<style>
  .hero {
    padding-block: var(--space-24) var(--space-20);
    overflow: hidden;
  }
  .hero-inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(360px, 0.85fr);
    gap: var(--space-16);
    align-items: center;
  }
  .hero-copy {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }
  .hero h1 {
    max-width: 11ch;
  }
  .hero-sub {
    font-size: var(--text-lg);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    max-width: 58ch;
  }
  .hero-ctas {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
  }
  .hero-proof {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-wrap: wrap;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-tertiary);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
  }
  .hero-proof .sep { color: var(--brand-accent); }
  .hero-visual {
    display: flex;
    justify-content: flex-end;
    position: relative;
  }
  .hero-orbit {
    position: absolute;
    border: 1px solid rgba(251, 191, 36, 0.16);
    border-radius: 999px;
    pointer-events: none;
  }
  .hero-orbit--one {
    width: 440px;
    height: 160px;
    right: -32px;
    top: 42px;
    transform: rotate(-18deg);
  }
  .hero-orbit--two {
    width: 360px;
    height: 120px;
    right: 12px;
    bottom: 40px;
    transform: rotate(16deg);
    border-color: rgba(93, 140, 93, 0.18);
  }

  .section-header {
    max-width: 68ch;
    margin-bottom: var(--space-12);
  }
  .section-sub {
    margin-top: var(--space-4);
    font-size: var(--text-base);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
  }
  .workflow-section,
  .method-section,
  .trust-section {
    background: var(--bg-surface);
  }
  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
  }
  .stats-section {
    border-block: 1px solid var(--border-subtle);
  }
  .stats-row {
    display: flex;
    flex-wrap: wrap;
  }
  .sector-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-5);
  }
  .sector-card {
    min-height: 230px;
    padding: var(--space-6);
    background: var(--bg-surface);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-xl);
  }
  .sector-card h3 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-4);
  }
  .sector-card p {
    color: var(--text-secondary);
    font-size: var(--text-sm);
  }
  .trust-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: var(--space-16);
    align-items: start;
  }
  .trust-copy p {
    color: var(--text-secondary);
    font-size: var(--text-lg);
  }
  .trust-list {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-5);
  }
  .trust-card {
    min-height: 210px;
    padding: var(--space-6);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-xl);
    background:
      linear-gradient(180deg, rgba(93,140,93,0.08), transparent),
      var(--bg-main);
  }
  .trust-card h3 {
    font-size: var(--text-lg);
    margin-bottom: var(--space-3);
  }
  .trust-card p {
    color: var(--text-secondary);
    font-size: var(--text-sm);
  }
  .method-grid {
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    gap: var(--space-16);
    align-items: start;
  }
  .method-copy p {
    color: var(--text-secondary);
    font-size: var(--text-lg);
  }
  .method-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .method-item {
    display: grid;
    grid-template-columns: 48px 1fr;
    gap: var(--space-5);
    padding: var(--space-6);
    background: var(--bg-main);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
  }
  .method-item span {
    font-family: var(--font-mono);
    color: var(--brand-accent);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-widest);
  }
  .method-item h3 {
    font-size: var(--text-lg);
    margin-bottom: var(--space-2);
  }
  .method-item p {
    color: var(--text-secondary);
    font-size: var(--text-sm);
  }
  .demo-section {
    border-block: 1px solid var(--border-subtle);
  }
  .demo-header {
    max-width: 760px;
    margin-bottom: var(--space-12);
  }
  .demo-header p {
    color: var(--text-secondary);
    font-size: var(--text-lg);
  }
  .demo-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
  }
  .workflow-demo {
    min-height: 560px;
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    padding: var(--space-6);
    background:
      linear-gradient(180deg, rgba(93,140,93,0.08), transparent 38%),
      var(--bg-surface);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-xl);
    position: relative;
    overflow: hidden;
  }
  .workflow-demo::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.035) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.035) 1px, transparent 1px);
    background-size: 28px 28px;
    mask-image: linear-gradient(to bottom, black, transparent 70%);
    pointer-events: none;
  }
  .workflow-demo > * {
    position: relative;
    z-index: 1;
  }
  .workflow-demo-top {
    display: flex;
    justify-content: space-between;
    gap: var(--space-4);
    align-items: center;
  }
  .workflow-demo-label,
  .workflow-demo-live {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    text-transform: uppercase;
    letter-spacing: var(--tracking-widest);
  }
  .workflow-demo-label { color: var(--brand-primary); }
  .workflow-demo-live {
    color: var(--brand-accent);
    border: 1px solid rgba(251,191,36,0.22);
    border-radius: var(--radius-full);
    padding: 4px 8px;
    background: rgba(251,191,36,0.06);
  }
  .workflow-demo h3 {
    font-size: var(--text-2xl);
    line-height: var(--leading-snug);
  }
  .workflow-demo-metric {
    padding: var(--space-5);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    background: var(--bg-main);
  }
  .workflow-demo-metric span {
    display: block;
    color: var(--text-primary);
    font-family: var(--font-heading);
    font-size: var(--text-4xl);
    font-weight: var(--weight-bold);
    line-height: 1;
  }
  .workflow-demo-metric p {
    margin-top: var(--space-2);
    color: var(--text-tertiary);
    font-size: var(--text-sm);
  }
  .workflow-demo-rows {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .workflow-demo-row {
    display: flex;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-3);
    border-radius: var(--radius-md);
    background: rgba(10,10,12,0.58);
    border: 1px solid var(--border-subtle);
  }
  .workflow-demo-row span {
    color: var(--text-disabled);
    font-size: var(--text-xs);
  }
  .workflow-demo-row strong {
    color: var(--text-secondary);
    font-size: var(--text-xs);
    text-align: right;
  }
  .workflow-timeline {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-top: auto;
  }
  .workflow-step {
