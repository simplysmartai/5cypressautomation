---
import Layout from '../../layouts/Layout.astro';
import Button from '../../components/Button.astro';
import JsonLd from '../../components/JsonLd.astro';
import { services } from '../../data/services';

const icons: Record<string, string> = {
  'practice-kpi-dashboard':    'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
  'monthly-client-snapshot':   'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
  'document-intake-ai-sort':   'M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12',
  'engagement-onboarding-flow':'M13 10V3L4 14h7v7l9-11h-7z',
  'missed-lead-text-back':     'M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z',
  'month-end-close-accelerator': 'M13 10V3L4 14h7v7l9-11h-7z',
  'ar-collections-agent':        'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
  'cashflow-forecast-agent':     'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6',
  'business-intelligence-dashboard': 'M3 3v18h18M7 14l3-3 4 4 5-7',
  'excel-spreadsheet-automation':    'M4 6h16M4 10h16M4 14h16M4 18h16M9 4v16M15 4v16',
};
---

<Layout
  title="Automation Services for Accounting Firms | 5 Cypress"
  description="Ten purpose-built automation systems for CPA firms, fractional CFO practices, and small businesses — from same-day Month-End Close to BI dashboards and Excel automation. No-code tools not required."
>
  <Fragment slot="head">
    <JsonLd schema={{
      '@context': 'https://schema.org',
      '@type': 'ItemList',
      name: '5 Cypress Automation Services',
      itemListElement: services.map((s, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        name: s.title,
        url: `https://www.5cypress.com/services/${s.slug}`,
      })),
    }} />
  </Fragment>

  <!-- Hero -->
  <section class="services-hero section">
    <div class="container">
      <div class="services-hero-inner reveal">
        <p class="lead-in">Services</p>
        <h1>Ten automations.<br/><em>Built for your practice.</em></h1>
        <p class="services-hero-sub">
          Each system is scoped, built, and documented for your specific stack —
          not a generic tool you configure yourself. We deliver working software
          with a runbook and a maintenance path.
        </p>
        <div class="services-meta">
          <div class="services-meta-item">
            <span class="meta-value">5–21</span>
            <span class="meta-label">business days to live</span>
          </div>
          <div class="services-meta-sep"></div>
          <div class="services-meta-item">
            <span class="meta-value">From $997</span>
            <span class="meta-label">setup</span>
          </div>
          <div class="services-meta-sep"></div>
          <div class="services-meta-item">
            <span class="meta-value">No-code</span>
            <span class="meta-label">tools not required</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services list -->
  <section class="section">
    <div class="container">
      <div class="services-list">
        {services.map((service, i) => (
          <article class="service-row reveal" id={service.slug}>
            <div class="service-row-number">
              <span>{String(i + 1).padStart(2, '0')}</span>
            </div>

            <div class="service-row-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d={icons[service.slug]} />
              </svg>
            </div>

            <div class="service-row-content">
              <p class="service-row-tag">{service.tag}</p>
              <h2 class="service-row-title">{service.title}</h2>
              <p class="service-row-tagline">{service.tagline}</p>
              <p class="service-row-desc">{service.description}</p>

              <div class="service-row-outcomes">
                {service.outcomes.slice(0, 3).map((o) => (
                  <div class="outcome-item">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                    </svg>
                    <span>{o}</span>
                  </div>
                ))}
              </div>

              <div class="service-row-stack">
                {service.stack.map((t) => (
                  <span class="stack-pill">{t}</span>
                ))}
              </div>
            </div>

            <div class="service-row-cta">
              <div class="service-pricing">
                <p class="pricing-setup">{service.setupPrice}</p>
                <p class="pricing-label">setup</p>
                {service.monthlyPrice && (
                  <>
                    <p class="pricing-monthly">{service.monthlyPrice}</p>
                    <p class="pricing-label">monthly</p>
                  </>
                )}
                <p class="pricing-timeline">{service.timeline} to live</p>
              </div>
              <Button variant="primary" size="md" href={`/services/${service.slug}`} magnetic ripple>
                Learn more
              </Button>
              <Button variant="ghost" size="md" magnetic ripple data-open-booking>
                Book a call
              </Button>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="section services-bottom-cta">
    <div class="container">
      <div class="bottom-cta-inner reveal">
        <p class="lead-in">Not sure where to start?</p>
        <h2>We'll tell you exactly<br/><em>what to automate first.</em></h2>
        <p>
          A 20-minute fit call covers your current stack, where hours are going,
          and which automation would pay for itself fastest.
        </p>
        <Button variant="primary" size="lg" magnetic ripple data-open-booking>
          Book a free fit call
        </Button>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ── Hero ─────────────────────────────────────────────────── */
  .services-hero { padding-block: var(--space-24) var(--space-16); }
  .services-hero-inner { max-width: 760px; }
  .services-hero-sub {
    font-size: var(--text-lg);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    margin-top: var(--space-4);
    max-width: 56ch;
  }
  .services-meta {
    display: flex;
    align-items: center;
    gap: var(--space-8);
    flex-wrap: wrap;
    margin-top: var(--space-10);
    padding: var(--space-6) var(--space-8);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-xl);
    background: var(--bg-surface);
    width: fit-content;
  }
  .services-meta-item { display: flex; flex-direction: column; gap: 2px; }
  .meta-value {
    font-family: var(--font-heading);
    font-weight: var(--weight-bold);
    font-size: var(--text-lg);
    color: var(--text-primary);
  }
  .meta-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-disabled);
    text-transform: uppercase;
    letter-spacing: var(--tracking-widest);
  }
  .services-meta-sep { width: 1px; height: 36px; background: var(--border-subtle); }

  /* ── Service rows ─────────────────────────────────────────── */
  .services-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .service-row {
    display: grid;
    grid-template-columns: 48px 64px 1fr 240px;
    gap: var(--space-8);
    align-items: start;
    padding: var(--space-12) 0;
    border-bottom: 1px solid var(--border-subtle);
    transition: background var(--duration-fast);
  }
  .service-row:first-child { border-top: 1px solid var(--border-subtle); }

  .service-row-number {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-disabled);
    padding-top: var(--space-1);
  }

  .service-row-icon svg {
    width: 40px;
    height: 40px;
    color: var(--brand-primary);
    margin-top: var(--space-1);
  }

  .service-row-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .service-row-tag {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--brand-primary);
  }
  .service-row-title {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    font-weight: var(--weight-bold);
    color: var(--text-primary);
    line-height: var(--leading-snug);
  }
  .service-row-tagline {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--text-base);
    color: var(--text-secondary);
  }
  .service-row-desc {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    max-width: 60ch;
  }

  .service-row-outcomes {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .outcome-item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-2);
    font-size: var(--text-xs);
    color: var(--text-tertiary);
  }
  .outcome-item svg { color: var(--success); flex-shrink: 0; margin-top: 2px; }

  .service-row-stack {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }
  .stack-pill {
    padding: 3px 10px;
    background: var(--bg-main);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-full);
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--text-disabled);
  }

  /* ── CTA column ───────────────────────────────────────────── */
  .service-row-cta {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    align-items: flex-start;
    padding: var(--space-6);
    background: var(--bg-surface);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-xl);
    position: sticky;
    top: var(--space-24);
  }
  .service-pricing { display: grid; grid-template-columns: auto 1fr; gap: 2px var(--space-3); align-items: baseline; margin-bottom: var(--space-2); }
  .pricing-setup {
    font-family: var(--font-heading);
    font-weight: var(--weight-bold);
    font-size: var(--text-xl);
    color: var(--text-primary);
  }
  .pricing-monthly {
    font-family: var(--font-heading);
    font-weight: var(--weight-semibold);
    font-size: var(--text-base);
    color: var(--text-secondary);
  }
  .pricing-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-disabled);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
  }
  .pricing-timeline {
    grid-column: span 2;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--brand-primary);
    margin-top: var(--space-2);
  }

  /* ── Bottom CTA ───────────────────────────────────────────── */
  .services-bottom-cta { background: var(--bg-surface); border-top: 1px solid var(--border-subtle); }
  .bottom-cta-inner {
    max-width: 560px;
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }
  .bottom-cta-inner p { color: var(--text-secondary); font-size: var(--text-base); line-height: var(--leading-relaxed); }

  /* ── Responsive ───────────────────────────────────────────── */
  @media (max-width: 1024px) {
    .service-row { grid-template-columns: 48px 1fr; grid-template-rows: auto auto; }
    .service-row-icon { display: none; }
    .service-row-cta { position: static; grid-column: 2; }
  }
  @media (max-width: 640px) {
    .service-row { grid-template-columns: 1fr; gap: var(--space-6); }
    .service-row-number { display: none; }
    .services-meta { gap: var(--space-6); }
    .services-meta-sep { display: none; }
  }
</style>
