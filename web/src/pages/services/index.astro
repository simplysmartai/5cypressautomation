---
import Layout from '../../layouts/Layout.astro';
import Button from '../../components/Button.astro';
import JsonLd from '../../components/JsonLd.astro';
import { services } from '../../data/services';

const workflowSystems = [
  {
    num: '01',
    label: 'Lead flow',
    title: 'Lead capture and follow-up',
    description:
      'Capture form fills, missed calls, referrals, and ad leads. Create the record, notify the owner, send the first reply, and keep the handoff from going cold.',
    examples: ['Missed-lead text-back', 'CRM routing', 'Referral intake', 'Owner alerts'],
    related: ['missed-lead-text-back'],
  },
  {
    num: '02',
    label: 'Reporting flow',
    title: 'Dashboards and KPI reporting',
    description:
      'Turn recurring exports and scattered metrics into dashboards, scheduled reports, and decision-ready summaries that update without spreadsheet work.',
    examples: ['BI dashboards', 'Client snapshots', 'KPI reports', 'Executive summaries'],
    related: ['business-intelligence-dashboard', 'practice-kpi-dashboard', 'monthly-client-snapshot'],
  },
  {
    num: '03',
    label: 'Document flow',
    title: 'Document intake and routing',
    description:
      'Collect files, classify them, rename them, route them to the right place, and flag exceptions for human review.',
    examples: ['Upload portals', 'AI file sorting', 'Folder routing', 'Exception queues'],
    related: ['document-intake-ai-sort'],
  },
  {
    num: '04',
    label: 'Money flow',
    title: 'Billing, invoice, and payment workflows',
    description:
      'Connect proposals, invoices, reminders, payment links, accounting records, and status updates so money workflows stop depending on manual re-entry.',
    examples: ['AR reminders', 'Invoice sync', 'Payment tracking', 'Cashflow alerts'],
    related: ['ar-collections-agent', 'cashflow-forecast-agent', 'month-end-close-accelerator'],
  },
  {
    num: '05',
    label: 'Onboarding flow',
    title: 'Client and customer onboarding',
    description:
      'Move a signed agreement, booked call, or new order into kickoff tasks, folders, calendar links, records, and internal notifications.',
    examples: ['Client setup', 'Kickoff routing', 'Task creation', 'Welcome sequences'],
    related: ['engagement-onboarding-flow', 'excel-spreadsheet-automation'],
  },
];

const serviceMap = Object.fromEntries(services.map((service) => [service.slug, service]));
---

<Layout
  title="Automation Services and Workflow Systems | 5 Cypress"
  description="Explore the five workflow systems 5 Cypress builds: lead follow-up, dashboards, document intake, billing flows, and onboarding automation."
>
  <Fragment slot="head">
    <JsonLd schema={{
      '@context': 'https://schema.org',
      '@type': 'ItemList',
      name: '5 Cypress Workflow Systems',
      itemListElement: workflowSystems.map((s, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        name: s.title,
        url: `https://www.5cypress.com/services/#workflow-${s.num}`,
      })),
    }} />
  </Fragment>

  <section class="services-hero section">
    <div class="container services-hero-grid">
      <div class="services-hero-copy reveal">
        <p class="lead-in">Services</p>
        <h1>Five workflow systems. Built around your business.</h1>
        <p class="services-hero-sub">
          Start with a proven automation pattern, then tune it to your tools, handoffs,
          approvals, data, and edge cases. Accounting and finance are a specialty,
          not a boundary.
        </p>
        <div class="services-actions">
          <Button variant="primary" size="lg" magnetic ripple data-open-booking>
            Book a Workflow Call
          </Button>
          <Button variant="secondary" size="lg" href="#automation-library">
            View example builds
          </Button>
        </div>
      </div>

      <div class="services-proof reveal">
        <div class="proof-row">
          <span>5-14</span>
          <p>business days for focused workflows</p>
        </div>
        <div class="proof-row">
          <span>3-4</span>
          <p>weeks for multi-system builds</p>
        </div>
        <div class="proof-row">
          <span>0</span>
          <p>new platform required by default</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section systems-section">
    <div class="container">
      <div class="section-header reveal">
        <p class="lead-in">The 5 Cypress model</p>
        <h2>Ready-to-build systems, customized after discovery.</h2>
        <p class="section-sub">
          Each system solves a universal business problem. The final build changes based on
          your industry, tools, volume, approval rules, and risk level.
        </p>
      </div>

      <div class="systems-list">
        {workflowSystems.map((system) => (
          <article class="system-row reveal" id={`workflow-${system.num}`}>
            <div class="system-num">{system.num}</div>
            <div class="system-main">
              <p class="system-label">{system.label}</p>
              <h3>{system.title}</h3>
              <p>{system.description}</p>
              <div class="example-pills">
                {system.examples.map((example) => (
                  <span>{example}</span>
                ))}
              </div>
            </div>
            <div class="system-related">
              <p class="related-label">Example builds</p>
              {system.related.map((slug) => {
                const related = serviceMap[slug];
                return related && (
                  <a href={`/services/${related.slug}/`} class="related-link">
                    <span>{related.shortTitle}</span>
                    <small>{related.timeline}</small>
                  </a>
                );
              })}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section specialty-section">
    <div class="container specialty-grid">
      <div class="specialty-copy reveal">
        <p class="lead-in">Specialty lane</p>
        <h2>Accounting and finance stays on the site for a reason.</h2>
        <p>
          Those teams have dense workflows: QBO data, document intake, client reports,
          invoice follow-up, close packages, and partner dashboards. That makes the niche
          a strong proof point while the core service stays broader.
        </p>
      </div>
      <div class="specialty-card reveal">
        <span>Useful for</span>
        <ul>
          <li>CPA and bookkeeping firms</li>
          <li>Fractional CFO practices</li>
          <li>Service businesses with lead leakage</li>
          <li>Medical and professional offices</li>
          <li>Any team rebuilding the same report every week</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="section" id="automation-library">
    <div class="container">
      <div class="section-header reveal">
        <p class="lead-in">Automation library</p>
        <h2>Examples of what we can build.</h2>
        <p class="section-sub">
          These are specific service pages and starting points. Some are accounting-focused
          today; the underlying patterns can be adapted for other businesses.
        </p>
      </div>

      <div class="library-grid reveal-stagger">
        {services.map((service) => (
          <a class="library-card" href={`/services/${service.slug}/`}>
            <div>
              <p class="library-tag">{service.tag}</p>
              <h3>{service.title}</h3>
              <p>{service.description}</p>
            </div>
            <div class="library-meta">
              <span>{service.setupPrice}</span>
              <small>{service.timeline}</small>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section services-bottom-cta">
    <div class="container">
      <div class="bottom-cta-inner reveal">
        <p class="lead-in">Not sure which system fits?</p>
        <h2>Bring the workflow. We'll map the first useful build.</h2>
        <p>
          A 20-minute workflow call is enough to identify the highest-leverage workflow,
          what systems it touches, and what should be built first.
        </p>
        <Button variant="primary" size="lg" magnetic ripple data-open-booking>
          Book a Workflow Call
        </Button>
      </div>
    </div>
  </section>
</Layout>

<style>
  .services-hero {
    padding-block: var(--space-24) var(--space-16);
  }
  .services-hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 340px;
    gap: var(--space-16);
    align-items: center;
  }
  .services-hero-copy {
    max-width: 760px;
  }
  .services-hero h1 {
    max-width: 12ch;
  }
  .services-hero-sub {
    font-size: var(--text-lg);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    margin-top: var(--space-5);
    max-width: 58ch;
  }
  .services-actions {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
    margin-top: var(--space-8);
  }
  .services-proof {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding: var(--space-6);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-xl);
    background:
      linear-gradient(180deg, rgba(93,140,93,0.08), transparent),
      var(--bg-surface);
  }
  .proof-row {
    display: grid;
    grid-template-columns: 82px 1fr;
    gap: var(--space-4);
    align-items: center;
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--border-subtle);
  }
  .proof-row:last-child {
    padding-bottom: 0;
    border-bottom: 0;
  }
  .proof-row span {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    font-weight: var(--weight-bold);
    color: var(--brand-accent);
  }
  .proof-row p {
    color: var(--text-secondary);
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
  }
  .section-header {
    max-width: 720px;
    margin-bottom: var(--space-12);
  }
  .section-sub {
    color: var(--text-secondary);
    margin-top: var(--space-4);
  }
  .systems-section,
  .services-bottom-cta {
    background: var(--bg-surface);
    border-block: 1px solid var(--border-subtle);
  }
  .systems-list {
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--border-subtle);
  }
  .system-row {
    display: grid;
    grid-template-columns: 72px minmax(0, 1fr) 320px;
    gap: var(--space-8);
    padding: var(--space-10) 0;
    border-bottom: 1px solid var(--border-subtle);
  }
  .system-num {
    font-family: var(--font-mono);
    color: var(--brand-accent);
    letter-spacing: var(--tracking-widest);
    font-size: var(--text-xs);
  }
  .system-label,
  .related-label,
  .library-tag,
  .specialty-card span {
    font-family: var(--font-mono);
    color: var(--brand-primary);
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
  }
  .system-main h3 {
    margin-top: var(--space-2);
    margin-bottom: var(--space-4);
    font-size: var(--text-2xl);
  }
  .system-main p {
    color: var(--text-secondary);
    max-width: 64ch;
  }
  .example-pills {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-5);
  }
  .example-pills span {
    padding: 5px 10px;
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-full);
    background: var(--bg-main);
    color: var(--text-tertiary);
    font-size: var(--text-xs);
  }
  .system-related {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .related-link {
    display: flex;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-3);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
    background: var(--bg-main);
  }
  .related-link span {
    color: var(--text-secondary);
    font-size: var(--text-sm);
  }
  .related-link small {
    color: var(--text-disabled);
    font-family: var(--font-mono);
    font-size: 0.65rem;
    text-align: right;
  }
  .specialty-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(320px, 0.55fr);
    gap: var(--space-16);
    align-items: start;
  }
  .specialty-copy p {
    color: var(--text-secondary);
    font-size: var(--text-lg);
    margin-top: var(--space-5);
  }
  .specialty-card {
    padding: var(--space-8);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-xl);
    background: var(--bg-surface);
  }
  .specialty-card ul {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-top: var(--space-5);
  }
  .specialty-card li {
    color: var(--text-secondary);
    font-size: var(--text-sm);
  }
  .library-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-5);
  }
  .library-card {
    display: flex;
    justify-content: space-between;
    gap: var(--space-8);
    padding: var(--space-6);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-xl);
    background: var(--bg-surface);
    transition:
      border-color var(--duration-fast),
      transform var(--duration-fast),
      box-shadow var(--duration-fast);
  }
  .library-card:hover {
    border-color: var(--border-brand);
    transform: translateY(-3px);
    box-shadow: var(--shadow-glow);
  }
  .library-card h3 {
    margin-top: var(--space-2);
    margin-bottom: var(--space-3);
    font-size: var(--text-xl);
  }
  .library-card p {
    color: var(--text-secondary);
    font-size: var(--text-sm);
  }
  .library-meta {
    min-width: 130px;
    text-align: right;
  }
  .library-meta span {
    display: block;
    color: var(--text-primary);
    font-family: var(--font-heading);
    font-weight: var(--weight-bold);
  }
  .library-meta small {
    color: var(--text-disabled);
    font-family: var(--font-mono);
    font-size: 0.65rem;
  }
  .bottom-cta-inner {
    max-width: 680px;
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }
  .bottom-cta-inner p {
    color: var(--text-secondary);
    font-size: var(--text-base);
  }
  @media (max-width: 1024px) {
    .services-hero-grid,
    .system-row,
    .specialty-grid {
      grid-template-columns: 1fr;
    }
    .services-proof,
    .system-related {
      max-width: 560px;
    }
    .library-grid {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 640px) {
    .services-hero h1 {
      max-width: none;
    }
    .library-card {
      flex-direction: column;
    }
    .library-meta {
      text-align: left;
    }
  }
</style>
