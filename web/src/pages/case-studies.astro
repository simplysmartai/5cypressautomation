---
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';
import JsonLd from '../components/JsonLd.astro';

const studies = [
  {
    id: 'cpa-kpi',
    client: 'Regional CPA Firm',
    segment: '6-partner firm · 2,200+ clients · Southeast US',
    service: 'Practice KPI Dashboard',
    serviceSlug: 'practice-kpi-dashboard',
    tag: 'Dashboard',
    problem: "Partners were running QBO reports manually twice a month and emailing screenshots to each other. No shared view. AR aging was tracked in a spreadsheet updated by one staff member. When that person left, the spreadsheet stopped being updated.",
    solution: "We built a live dashboard pulling from QBO and their Karbon instance — realization rate, WIP by partner, AR aging buckets, and billing trend. One URL, updated every 4 hours, accessible from any device.",
    timeline: '12 business days',
    results: [
      { stat: '3.5 hrs', label: 'saved per partner per month on reporting' },
      { stat: '22%', label: 'reduction in overdue AR within 60 days of going live' },
      { stat: '0 hrs', label: 'staff time on manual spreadsheet updates' },
      { stat: '1 URL', label: 'every partner shares the same view, live' },
    ],
    quote: "We used to argue in Monday meetings about whose numbers were right. Now there's one source and everyone uses it.",
    attribution: 'Managing Partner',
  },
  {
    id: 'fractional-cfo-snapshot',
    client: 'Fractional CFO Practice',
    segment: '1 CFO · 14 SMB clients · Monthly close reporting',
    service: 'Monthly Client Snapshot',
    serviceSlug: 'monthly-client-snapshot',
    tag: 'Reporting',
    problem: "Every month, the CFO spent 6–8 hours building client reports: exporting QBO, reformatting in Excel, copying into a branded template, emailing. For 14 clients. The same 6–8 hours every month.",
    solution: "We automated the full chain. QBO close triggers generation. Each client gets a branded PDF report and a live web dashboard — auto-delivered before the 5th. The CFO reviews but does not rebuild.",
    timeline: '10 business days',
    results: [
      { stat: '7 hrs', label: 'reclaimed every month on report generation' },
      { stat: '14 clients', label: 'each receiving branded, individualized reports' },
      { stat: 'Day 3', label: 'reports delivered — before clients ask' },
      { stat: '2 new clients', label: 'added with zero additional reporting overhead' },
    ],
    quote: "I added two clients immediately after launch because I knew the reporting wasn't going to consume me. That's $2,400/month in new revenue directly traceable to this system.",
    attribution: 'Fractional CFO, Founder',
  },
  {
    id: 'tax-firm-doc-intake',
    client: 'Tax & Bookkeeping Firm',
    segment: '3-person team · 380 individual tax clients',
    service: 'Document Intake & AI Sort',
    serviceSlug: 'document-intake-ai-sort',
    tag: 'AI · Intake',
    problem: "Tax season meant clients emailing documents to whoever they knew at the firm — sometimes to the owner's personal email, sometimes as 12 separate attachments. Staff spent the first three weeks of season just sorting and naming files.",
    solution: "We built a client-facing upload portal and connected it to OpenAI Vision for classification. Every uploaded document is identified, renamed to convention, and routed to the correct TaxDome job folder automatically.",
    timeline: '16 business days',
    results: [
      { stat: '47 hrs', label: 'staff time saved in first tax season' },
      { stat: '<5 sec', label: 'per document: classified and filed' },
      { stat: '0', label: 'misfiled documents in first season (vs. 12+ prior year)' },
      { stat: '380 clients', label: 'each receiving a personal upload link with instructions' },
    ],
    quote: "The first week of tax season used to feel like triage. This year it felt like February.",
    attribution: 'Firm Owner',
  },
];
---

<Layout
  title="Case Studies | 5 Cypress Automation"
  description="Real results from accounting and finance firms using 5 Cypress automation systems — Practice KPI dashboards, automated client reports, and AI document intake."
>
  <Fragment slot="head">
    <JsonLd schema={{
      '@context': 'https://schema.org',
      '@type': 'ItemList',
      name: '5 Cypress Case Studies',
      description: 'Automation results for accounting and finance firms',
      itemListElement: studies.map((s, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        name: `${s.client}: ${s.service}`,
        url: `https://www.5cypress.com/case-studies#${s.id}`,
      })),
    }} />
  </Fragment>

  <!-- Hero -->
  <section class="cs-hero section">
    <div class="container">
      <div class="cs-hero-inner reveal">
        <p class="lead-in">Case Studies</p>
        <h1>What automation<br/><em>actually looks like.</em></h1>
        <p class="cs-hero-sub">
          Three results from firms that had a clear, repeatable problem and the
          patience to let automation solve it properly. Clients are anonymized;
          numbers are real.
        </p>
      </div>
    </div>
  </section>

  <!-- Studies -->
  {studies.map((study, i) => (
    <section class={`section cs-study ${i % 2 === 1 ? 'cs-study--alt' : ''}`} id={study.id}>
      <div class="container">
        <!-- Header -->
        <div class="cs-study-header reveal">
          <div class="cs-meta">
            <span class="cs-tag">{study.tag}</span>
            <span class="cs-client">{study.client}</span>
            <span class="cs-segment">{study.segment}</span>
          </div>
          <div class="cs-service-link">
            <a href={`/services/${study.serviceSlug}`}>
              Service: {study.service} →
            </a>
          </div>
        </div>

        <!-- Main grid -->
        <div class="cs-study-grid">
          <!-- Left: problem / solution -->
          <div class="cs-narrative reveal">
            <div class="narrative-block">
              <div class="narrative-label">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <circle cx="12" cy="12" r="10"/>
                  <line x1="15" y1="9" x2="9" y2="15"/>
                  <line x1="9" y1="9" x2="15" y2="15"/>
                </svg>
                The problem
              </div>
              <p>{study.problem}</p>
            </div>
            <div class="narrative-connector" aria-hidden="true">
              <div class="connector-line"></div>
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/>
              </svg>
            </div>
            <div class="narrative-block narrative-block--solution">
              <div class="narrative-label">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                </svg>
                The solution
              </div>
              <p>{study.solution}</p>
              <p class="narrative-timeline">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <circle cx="12" cy="12" r="10"/>
                  <polyline points="12 6 12 12 16 14"/>
                </svg>
                Live in {study.timeline}
              </p>
            </div>
          </div>

          <!-- Right: results -->
          <div class="cs-results reveal-stagger">
            <div class="results-grid">
              {study.results.map((r) => (
                <div class="result-tile">
                  <p class="result-stat">{r.stat}</p>
                  <p class="result-label">{r.label}</p>
                </div>
              ))}
            </div>
            <blockquote class="cs-quote">
              <p>"{study.quote}"</p>
              <footer>— {study.attribution}</footer>
            </blockquote>
          </div>
        </div>
      </div>
    </section>
  ))}

  <!-- Disclaimer -->
  <section class="section cs-disclaimer">
    <div class="container">
      <p class="disclaimer-text">
        Client names and identifying details are anonymized. Results vary based on
        firm size, existing systems, and data quality. Numbers reflect outcomes
        reported by clients during or after the 30-day support window.
      </p>
    </div>
  </section>

  <!-- CTA -->
  <section class="section cs-cta">
    <div class="container">
      <div class="cs-cta-inner reveal">
        <p class="lead-in">Your firm next?</p>
        <h2>Tell us the problem.<br/><em>We'll tell you if it's solvable.</em></h2>
        <p>
          A 20-minute fit call is enough to scope whether automation is the right
          tool for what you're dealing with — and what it would cost.
        </p>
        <div class="cs-cta-actions">
          <Button variant="primary" size="lg" magnetic ripple data-open-booking>
            Book a fit call
          </Button>
          <Button variant="ghost" size="lg" magnetic href="/services">
            See all services
          </Button>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ── Hero ─────────────────────────────────────────────────── */
  .cs-hero { padding-block: var(--space-24) var(--space-16); }
  .cs-hero-inner { max-width: 640px; }
  .cs-hero-sub {
    font-size: var(--text-lg);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    margin-top: var(--space-4);
    max-width: 52ch;
  }

  /* ── Study sections ───────────────────────────────────────── */
  .cs-study { border-top: 1px solid var(--border-subtle); }
  .cs-study--alt { background: var(--bg-surface); }

  /* Header row */
  .cs-study-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: var(--space-10);
    padding-bottom: var(--space-6);
    border-bottom: 1px solid var(--border-subtle);
  }
  .cs-meta { display: flex; flex-direction: column; gap: var(--space-1); }
  .cs-tag {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    text-transform: uppercase;
    letter-spacing: var(--tracking-widest);
    color: var(--brand-primary);
  }
  .cs-client {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    font-weight: var(--weight-bold);
    color: var(--text-primary);
  }
  .cs-segment {
    font-size: var(--text-sm);
    color: var(--text-tertiary);
  }
  .cs-service-link a {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--brand-accent);
    text-decoration: none;
  }
  .cs-service-link a:hover { color: var(--brand-accent-light); }

  /* Main grid */
  .cs-study-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-16);
    align-items: start;
  }

  /* Narrative */
  .cs-narrative { display: flex; flex-direction: column; gap: 0; }
  .narrative-block {
    padding: var(--space-7);
    background: var(--bg-main);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .narrative-block--solution { border-color: var(--border-brand); }
  .narrative-label {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    text-transform: uppercase;
    letter-spacing: var(--tracking-widest);
    color: var(--text-disabled);
  }
  .narrative-block--solution .narrative-label { color: var(--brand-primary); }
  .narrative-block--solution .narrative-label svg { color: var(--success); }
  .narrative-label svg { color: var(--error); }
  .narrative-block p {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
  }
  .narrative-timeline {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--brand-primary);
    margin-top: var(--space-2);
  }
  .narrative-connector {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-2) var(--space-4);
    color: var(--brand-primary);
  }
  .connector-line { flex: 1; height: 1px; background: var(--border-brand); }

  /* Results */
  .cs-results { display: flex; flex-direction: column; gap: var(--space-6); }
  .results-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3);
  }
  .result-tile {
    padding: var(--space-5) var(--space-6);
    background: var(--bg-surface);
    border: 1px solid var(--border-medium);
    border-radius: var(--radius-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }
  .result-stat {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--text-3xl);
    font-weight: var(--weight-bold);
    background: linear-gradient(135deg, var(--brand-primary-light), var(--brand-accent));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1.1;
  }
  .result-label {
    font-size: var(--text-xs);
    color: var(--text-tertiary);
    line-height: var(--leading-relaxed);
  }

  .cs-quote {
    padding: var(--space-6) var(--space-7);
    background: var(--bg-surface);
    border-left: 3px solid var(--brand-accent);
    border-radius: 0 var(--radius-lg) var(--radius-lg) 0;
    margin: 0;
  }
  .cs-quote p {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--text-base);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-3);
  }
  .cs-quote footer {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-disabled);
  }

  /* ── Disclaimer ───────────────────────────────────────────── */
  .disclaimer-text {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-disabled);
    line-height: var(--leading-relaxed);
    max-width: 72ch;
    border-top: 1px solid var(--border-subtle);
    padding-top: var(--space-6);
  }

  /* ── CTA ──────────────────────────────────────────────────── */
  .cs-cta { background: var(--bg-surface); border-top: 1px solid var(--border-subtle); }
  .cs-cta-inner {
    max-width: 560px;
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }
  .cs-cta-inner p { font-size: var(--text-base); color: var(--text-secondary); line-height: var(--leading-relaxed); }
  .cs-cta-actions { display: flex; gap: var(--space-4); flex-wrap: wrap; }

  /* ── Responsive ───────────────────────────────────────────── */
  @media (max-width: 1024px) {
    .cs-study-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 640px) {
    .cs-study-header { flex-direction: column; gap: var(--space-3); }
    .results-grid { grid-template-columns: 1fr 1fr; }
  }
</style>
