---
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';
import JsonLd from '../components/JsonLd.astro';

const examples = [
  {
    id: 'growth-command-center',
    title: 'B2B Growth Command Center',
    segment: 'Revenue, pipeline, marketing, invoices, automation, and account health',
    tag: 'BI Dashboard',
    problem: 'Past dashboard work contained sensitive company data, so the public site needed a portfolio-safe way to show real analytics judgment without exposing private information.',
    workflow: 'A synthetic B2B operating dataset powers an executive dashboard with revenue trend, weighted pipeline, channel ROI, invoice aging, workflow health, and renewal risk in one view.',
    href: '/dashboards/b2b-growth-command-center/',
    cta: 'Open Dashboard',
    results: [
      { stat: '18 mo', label: 'synthetic operating history modeled' },
      { stat: '6 views', label: 'revenue, sales, marketing, AR, workflow, accounts' },
      { stat: '0 client', label: 'records or confidential screenshots used' },
      { stat: '1 URL', label: 'site-ready interactive portfolio asset' },
    ],
  },
  {
    id: 'lead-flow',
    title: 'Service Business Lead Flow',
    segment: 'Calls, forms, CRM, email, and SMS',
    tag: 'Lead Follow-Up',
    problem: 'New inquiries were landing in different places, and the team was relying on memory to follow up. Hot leads could sit for hours before anyone owned them.',
    workflow: 'A new inquiry creates one lead record, assigns an owner, sends an internal alert, starts a follow-up sequence, and keeps the status visible until someone closes the loop.',
    results: [
      { stat: '<1 min', label: 'lead routed after form or missed call' },
      { stat: '3 channels', label: 'form, phone, and email brought into one flow' },
      { stat: '1 owner', label: 'assigned for every open lead' },
      { stat: '0 duplicates', label: 'before the CRM record is created' },
    ],
  },
  {
    id: 'reporting-flow',
    title: 'Operations Reporting Flow',
    segment: 'QuickBooks, CRM, spreadsheets, and dashboard',
    tag: 'Reporting',
    problem: 'Weekly reporting required exports, spreadsheet cleanup, screenshots, and manual commentary. The numbers changed depending on who built the report.',
    workflow: 'The dashboard pulls the same source data on a schedule, flags missing records, shows the core metrics, and gives leadership one shared place to check performance.',
    results: [
      { stat: '12 metrics', label: 'tracked in one operating view' },
      { stat: '1 URL', label: 'shared by the whole team' },
      { stat: 'Mon 8am', label: 'updated before the weekly meeting' },
      { stat: '0 exports', label: 'needed for the standard report' },
    ],
  },
  {
    id: 'document-flow',
    title: 'Document Intake Flow',
    segment: 'Upload form, shared drive, review queue, and alerts',
    tag: 'Document Intake',
    problem: 'Files arrived through email threads, shared links, and staff inboxes. Naming, sorting, and follow-up took too much time before the real work could start.',
    workflow: 'Clients upload files through one intake path. Each file is renamed, routed to the right folder, added to a review queue, and flagged when something is missing.',
    results: [
      { stat: '<5 sec', label: 'to route a standard document' },
      { stat: '4 folders', label: 'organized by workflow stage' },
      { stat: '2 exceptions', label: 'flagged for human review' },
      { stat: '1 queue', label: 'for staff to work from' },
    ],
  },
];
---

<Layout
  title="Workflow Examples | 5 Cypress Automation"
  description="Explore realistic workflow examples for lead follow-up, reporting, document intake, billing, and onboarding automation."
>
  <Fragment slot="head">
    <JsonLd schema={{
      '@context': 'https://schema.org',
      '@type': 'CollectionPage',
      name: '5 Cypress Workflow Examples',
      description: 'Representative workflow automation examples using realistic demo scenarios.',
      url: 'https://www.5cypress.com/case-studies',
    }} />
  </Fragment>

  <section class="examples-hero section">
    <div class="container">
      <div class="examples-hero-inner reveal">
        <p class="lead-in">Workflow Examples</p>
        <h1>Realistic workflow examples, without pretending they are case studies.</h1>
        <p class="examples-hero-sub">
          These demo scenarios show the shape of the work: where the workflow starts,
          what gets connected, what changes, and what the team gets back. Public
          client stories can be added here as the brand grows.
        </p>
      </div>
    </div>
  </section>

  <section class="section examples-section">
    <div class="container">
      <div class="examples-list">
        {examples.map((example, index) => (
          <article class="example-card reveal" id={example.id}>
            <div class="example-index">
              <span>{String(index + 1).padStart(2, '0')}</span>
              <p>{example.tag}</p>
            </div>

            <div class="example-main">
              <p class="example-segment">{example.segment}</p>
              <h2>{example.title}</h2>

              <div class="example-columns">
                <div>
                  <h3>Before</h3>
                  <p>{example.problem}</p>
                </div>
                <div>
                  <h3>Workflow</h3>
                  <p>{example.workflow}</p>
                </div>
              </div>

              <div class="results-grid">
                {example.results.map((result) => (
                  <div class="result-card">
                    <strong>{result.stat}</strong>
                    <span>{result.label}</span>
                  </div>
                ))}
              </div>

              {example.href && (
                <div class="example-action">
                  <Button href={example.href} variant="secondary">{example.cta}</Button>
                </div>
              )}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section note-section">
    <div class="container">
      <div class="note-panel reveal">
        <p class="lead-in">About These Examples</p>
        <h2>Demo data now. Real proof as the portfolio grows.</h2>
        <p>
          This page is intentionally framed as workflow examples, not public client
          case studies. It gives prospects a concrete view of the systems 5 Cypress
          can build without overstating proof that has not been packaged yet.
        </p>
      </div>
    </div>
  </section>

  <section class="section cta-section">
    <div class="container">
      <div class="cta-panel reveal">
        <div>
          <p class="lead-in">Your Workflow</p>
          <h2>Have a version of one of these inside your business?</h2>
        </div>
        <div class="cta-actions">
          <Button variant="primary" size="lg" magnetic ripple data-open-booking>
            Map My Workflow
          </Button>
          <Button variant="secondary" size="lg" href="/services/">
            View Services
          </Button>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .examples-hero {
    padding: calc(var(--space-24) + 3rem) 0 var(--space-24);
    background:
      linear-gradient(135deg, rgba(42, 71, 54, 0.09), transparent 48%),
      linear-gradient(180deg, var(--bg-main), var(--bg-surface));
  }

  .examples-hero-inner {
    max-width: 920px;
  }

  .examples-hero h1 {
    margin: 0 0 var(--space-6);
    color: var(--text-primary);
    font-size: clamp(3.2rem, 8vw, 7.5rem);
    line-height: 0.94;
    letter-spacing: 0;
  }

  .examples-hero-sub {
    max-width: 760px;
    color: var(--text-secondary);
    font-size: clamp(1.1rem, 2vw, 1.35rem);
    line-height: 1.7;
  }

  .examples-list {
    display: grid;
    gap: var(--space-6);
  }

  .example-card {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: var(--space-8);
    border: 1px solid var(--border-medium);
    border-radius: 8px;
    background: var(--bg-surface);
    padding: var(--space-8);
  }

  .example-index span {
    display: block;
    color: var(--brand-accent);
    font-family: var(--font-mono);
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: var(--space-3);
  }

  .example-index p,
  .example-segment {
    margin: 0;
    color: var(--brand-primary);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .example-main h2 {
    margin: var(--space-3) 0 var(--space-6);
    color: var(--text-primary);
    font-size: clamp(2rem, 4vw, 3.8rem);
    line-height: 1.02;
    letter-spacing: 0;
  }

  .example-columns {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-6);
    margin-bottom: var(--space-6);
  }

  .example-columns h3 {
    margin: 0 0 var(--space-3);
    color: var(--text-primary);
    font-size: 1rem;
  }

  .example-columns p {
    margin: 0;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  .results-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-3);
  }

  .example-action {
    margin-top: var(--space-6);
  }

  .result-card {
    min-height: 128px;
    border: 1px solid var(--border-medium);
    border-radius: 8px;
    padding: var(--space-4);
    background: var(--bg-main);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .result-card strong {
    color: var(--brand-primary);
    font-size: 1.65rem;
    line-height: 1;
  }

  .result-card span {
    color: var(--text-secondary);
    line-height: 1.45;
  }

  .note-panel,
  .cta-panel {
    border: 1px solid var(--border-medium);
    border-radius: 8px;
    background: var(--bg-surface);
    padding: var(--space-12);
  }

  .note-panel {
    max-width: 920px;
  }

  .note-panel h2,
  .cta-panel h2 {
    margin: 0 0 var(--space-4);
    color: var(--text-primary);
    font-size: clamp(2rem, 4vw, 3.6rem);
    line-height: 1.05;
    letter-spacing: 0;
  }

  .note-panel p {
    color: var(--text-secondary);
    line-height: 1.75;
    font-size: 1.05rem;
  }

  .cta-panel {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--space-8);
    align-items: center;
    background:
      linear-gradient(135deg, rgba(42, 71, 54, 0.14), transparent 50%),
      var(--bg-surface);
  }

  .cta-actions {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  @media (max-width: 1000px) {
    .example-card,
    .cta-panel {
      grid-template-columns: 1fr;
    }

    .results-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .cta-actions {
      justify-content: flex-start;
    }
  }

  @media (max-width: 700px) {
    .example-columns,
    .results-grid {
      grid-template-columns: 1fr;
    }

    .example-card,
    .note-panel,
    .cta-panel {
      padding: var(--space-6);
    }
  }
</style>
