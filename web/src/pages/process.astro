---
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';
import JsonLd from '../components/JsonLd.astro';

const steps = [
  {
    number: '01',
    label: 'Map',
    title: 'Find the handoff that keeps breaking',
    body: 'We trace the current workflow from first trigger to final output: who touches it, where data moves, what gets copied, and where delays or errors show up.',
  },
  {
    number: '02',
    label: 'Design',
    title: 'Choose the simplest system that can hold up',
    body: 'You get a clear build plan with the tools involved, the human review points, the exception path, and the expected handoff when the system goes live.',
  },
  {
    number: '03',
    label: 'Build',
    title: 'Connect the workflow with real checks',
    body: 'The system is built around APIs, forms, files, dashboards, email, SMS, or internal tools depending on the job. Test data comes first, production comes later.',
  },
  {
    number: '04',
    label: 'Launch',
    title: 'Hand it off with documentation',
    body: 'We test the workflow end to end, document how it works, show your team how to handle exceptions, and leave you with something you can maintain.',
  },
];

const timelines = [
  ['Lead follow-up flow', '5 to 10 business days'],
  ['Reporting dashboard', '7 to 14 business days'],
  ['Document intake flow', '10 to 16 business days'],
  ['Billing or payment flow', '10 to 18 business days'],
  ['Client onboarding system', '10 to 20 business days'],
];
---

<Layout
  title="How We Build Automation | 5 Cypress Automation"
  description="See the 5 Cypress process for mapping, designing, building, and launching practical workflow automation for B2B teams."
>
  <Fragment slot="head">
    <JsonLd schema={{
      '@context': 'https://schema.org',
      '@type': 'HowTo',
      name: 'How 5 Cypress Builds Automation',
      description: 'The 4-step process for mapping, building, testing, and handing off a documented workflow automation system.',
      step: steps.map((step, index) => ({
        '@type': 'HowToStep',
        position: index + 1,
        name: step.label,
        text: step.body,
      })),
    }} />
  </Fragment>

  <section class="process-hero section">
    <div class="container">
      <div class="process-hero-inner reveal">
        <p class="lead-in">Process</p>
        <h1>From messy handoff to workflow your team can trust.</h1>
        <p class="process-hero-sub">
          The goal is not to make everything automatic. The goal is to make the
          repeatable work move cleanly, with the right checks and the right person
          still in control.
        </p>
      </div>
    </div>
  </section>

  <section class="section steps-section">
    <div class="container">
      <div class="steps-grid">
        {steps.map((step) => (
          <article class="step-card reveal">
            <div class="step-top">
              <span>{step.number}</span>
              <p>{step.label}</p>
            </div>
            <h2>{step.title}</h2>
            <p>{step.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section proof-section">
    <div class="container">
      <div class="proof-grid">
        <div class="proof-copy reveal">
          <p class="lead-in">What You Get</p>
          <h2>A workflow your team can understand after launch.</h2>
          <p>
            Every build includes the workflow map, a plain-English runbook, the
            systems connected, the trigger rules, and what to do when something
            needs review. That matters whether the workflow touches QuickBooks,
            a CRM, a form, a shared drive, or a dashboard.
          </p>
        </div>

        <div class="timeline-card reveal">
          <h3>Typical Build Windows</h3>
          <div class="timeline-list">
            {timelines.map(([name, time]) => (
              <div class="timeline-row">
                <span>{name}</span>
                <strong>{time}</strong>
              </div>
            ))}
          </div>
          <p>Exact timing depends on access, approvals, and how clean the source data is.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section rules-section">
    <div class="container">
      <div class="rules-panel reveal">
        <div>
          <p class="lead-in">Operating Rules</p>
          <h2>No magic box. No surprise handoff.</h2>
        </div>
        <ul>
          <li>Test data before production data.</li>
          <li>Human review where judgment is needed.</li>
          <li>Clear exception paths when an automation cannot complete.</li>
          <li>Documentation your team can actually use.</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="section cta-section">
    <div class="container">
      <div class="cta-panel reveal">
        <h2>Start with the handoff your team keeps cleaning up manually.</h2>
        <Button variant="primary" size="lg" magnetic ripple data-open-booking>
          Map My Workflow
        </Button>
      </div>
    </div>
  </section>
</Layout>

<style>
  .process-hero {
    padding: calc(var(--space-24) + 3rem) 0 var(--space-24);
    background:
      linear-gradient(135deg, rgba(42, 71, 54, 0.09), transparent 48%),
      linear-gradient(180deg, var(--bg-main), var(--bg-surface));
  }

  .process-hero-inner {
    max-width: 900px;
  }

  .process-hero h1 {
    margin: 0 0 var(--space-6);
    color: var(--text-primary);
    font-size: clamp(3.1rem, 8vw, 7.25rem);
    line-height: 0.94;
    letter-spacing: 0;
  }

  .process-hero-sub {
    max-width: 720px;
    color: var(--text-secondary);
    font-size: clamp(1.1rem, 2vw, 1.35rem);
    line-height: 1.7;
  }

  .steps-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-4);
  }

  .step-card {
    min-height: 350px;
    border: 1px solid var(--border-medium);
    border-radius: 8px;
    background: var(--bg-surface);
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
  }

  .step-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-6);
    color: var(--brand-accent);
    font-family: var(--font-mono);
    font-weight: 700;
  }

  .step-top p {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.78rem;
  }

  .step-card h2 {
    margin: 0 0 var(--space-4);
    color: var(--text-primary);
    font-size: 1.55rem;
    line-height: 1.15;
  }

  .step-card > p {
    margin: 0;
    color: var(--text-secondary);
    line-height: 1.65;
  }

  .proof-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(320px, 0.85fr);
    gap: var(--space-12);
    align-items: start;
  }

  .proof-copy h2,
  .rules-panel h2,
  .cta-panel h2 {
    margin: 0 0 var(--space-4);
    color: var(--text-primary);
    font-size: clamp(2rem, 4vw, 3.75rem);
    line-height: 1.05;
    letter-spacing: 0;
  }

  .proof-copy p {
    color: var(--text-secondary);
    font-size: 1.05rem;
    line-height: 1.75;
  }

  .timeline-card,
  .rules-panel,
  .cta-panel {
    border: 1px solid var(--border-medium);
    border-radius: 8px;
    background: var(--bg-surface);
    padding: var(--space-8);
  }

  .timeline-card h3 {
    margin: 0 0 var(--space-6);
    color: var(--text-primary);
    font-size: 1.4rem;
  }

  .timeline-row {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--space-4);
    padding: var(--space-4) 0;
    border-top: 1px solid var(--border-medium);
  }

  .timeline-row span {
    color: var(--text-secondary);
  }

  .timeline-row strong {
    color: var(--text-primary);
    white-space: nowrap;
  }

  .timeline-card > p {
    color: var(--text-tertiary);
    line-height: 1.6;
    margin: var(--space-6) 0 0;
  }

  .rules-panel {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: var(--space-8);
    align-items: start;
  }

  .rules-panel ul {
    margin: 0;
    padding-left: 1.2rem;
    color: var(--text-secondary);
    line-height: 1.9;
  }

  .cta-panel {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--space-8);
    align-items: center;
    background:
      linear-gradient(135deg, rgba(42, 71, 54, 0.14), transparent 50%),
      var(--bg-surface);
  }

  .cta-panel h2 {
    margin-bottom: 0;
  }

  @media (max-width: 1000px) {
    .steps-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .proof-grid,
    .rules-panel,
    .cta-panel {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .steps-grid {
      grid-template-columns: 1fr;
    }

    .timeline-row {
      grid-template-columns: 1fr;
      gap: var(--space-1);
    }
  }
</style>
