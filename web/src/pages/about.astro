---
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';
import JsonLd from '../components/JsonLd.astro';

const principles = [
  {
    title: 'Build around the real workflow',
    body: 'The work starts with how leads, files, invoices, reports, and handoffs actually move through your business today.',
  },
  {
    title: 'Use tools you can own',
    body: 'Systems are built with practical APIs, clear documentation, and handoff notes so you are not trapped inside a black box.',
  },
  {
    title: 'Automate what deserves it',
    body: 'Some problems need a workflow. Some need a better form, rule, or operating habit. The job is to tell the difference.',
  },
  {
    title: 'Keep humans in control',
    body: 'Good automation removes repetitive work while keeping review, exception handling, and accountability visible.',
  },
];

const systems = [
  'Lead follow-up',
  'Reporting dashboards',
  'Document intake',
  'Billing and payment flow',
  'Client onboarding',
];
---

<Layout
  title="About 5 Cypress Automation | Practical Workflow Systems"
  description="5 Cypress Automation builds practical workflow systems for growing B2B teams, with a specialty in accounting and finance operations."
>
  <Fragment slot="head">
    <JsonLd schema={{
      '@context': 'https://schema.org',
      '@type': 'AboutPage',
      name: 'About 5 Cypress Automation',
      url: 'https://www.5cypress.com/about',
      mainEntity: {
        '@type': 'Organization',
        name: '5 Cypress Automation',
        url: 'https://www.5cypress.com',
        email: 'nick@5cypress.com',
        description: 'Practical workflow automation for growing B2B teams, including lead follow-up, reporting, document intake, billing, and onboarding systems.',
        founder: {
          '@type': 'Person',
          name: 'Nick',
          jobTitle: 'Founder',
        },
      },
    }} />
  </Fragment>

  <section class="about-hero section">
    <div class="container">
      <div class="about-hero-inner reveal">
        <p class="lead-in">About</p>
        <h1>Practical automation, built for difficult ground.</h1>
        <p class="about-hero-sub">
          5 Cypress builds workflow systems for small B2B teams that have outgrown
          copy-paste operations but do not need a bloated software project or a
          new platform nobody asked for.
          Accounting and finance firms are a specialty, not the boundary.
        </p>
      </div>
    </div>
  </section>

  <section class="section origin-section">
    <div class="container">
      <div class="origin-grid">
        <div class="origin-copy reveal">
          <p class="lead-in">The Name</p>
          <h2>Built from the New Orleans idea of roots, resilience, and useful shade.</h2>
          <p>
            The Cypress part comes from growing up around the New Orleans area,
            where cypress trees are part of the landscape. They are steady, distinct,
            and built for difficult ground. That is the brand direction: grounded,
            useful, and not dressed up to look like every other AI company.
          </p>
          <p>
            The 5 points to the first set of ready-to-build workflow systems most
            growing companies eventually need. Each one can stand alone, connect to
            the others, or be adjusted for the way a specific team works.
          </p>
        </div>

        <div class="brand-card reveal">
          <img src="/assets/brand/5cypress-mark.svg" alt="5 Cypress Automation cypress tree mark" />
          <div>
            <span>5 Cypress Automation</span>
            <strong>Workflow systems for growing B2B teams</strong>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section systems-section">
    <div class="container">
      <div class="section-header reveal">
        <p class="lead-in">The Starting Five</p>
        <h2>Five workflows most teams need before they need another platform.</h2>
      </div>

      <div class="systems-list reveal">
        {systems.map((system, index) => (
          <div class="system-row">
            <span>{String(index + 1).padStart(2, '0')}</span>
            <strong>{system}</strong>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section principles-section">
    <div class="container">
      <div class="principles-grid">
        {principles.map((principle) => (
          <article class="principle-card reveal">
            <h3>{principle.title}</h3>
            <p>{principle.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section specialty-section">
    <div class="container">
      <div class="specialty-panel reveal">
        <p class="lead-in">Specialty</p>
        <h2>Accounting and finance workflows are still a strong lane.</h2>
        <p>
          QuickBooks, invoicing, client reporting, document intake, and financial
          dashboards are natural fits for 5 Cypress. The broader point is the same
          across sectors: clean handoffs, fewer duplicate entries, better follow-up,
          and systems your team can trust.
        </p>
        <Button variant="secondary" size="md" href="/services/">
          View Services
        </Button>
      </div>
    </div>
  </section>

  <section class="section cta-section">
    <div class="container">
      <div class="cta-panel reveal">
        <p class="lead-in">Next Step</p>
        <h2>Bring the messy workflow. We will map what should happen next.</h2>
        <Button variant="primary" size="lg" magnetic ripple data-open-booking>
          Map My Workflow
        </Button>
      </div>
    </div>
  </section>
</Layout>

<style>
  .about-hero {
    padding: calc(var(--space-24) + 3rem) 0 var(--space-24);
    background:
      linear-gradient(135deg, rgba(42, 71, 54, 0.08), transparent 46%),
      linear-gradient(180deg, var(--bg-main), var(--bg-surface));
  }

  .about-hero-inner {
    max-width: 860px;
  }

  .about-hero h1 {
    font-size: clamp(3.2rem, 8vw, 7.5rem);
    line-height: 0.94;
    letter-spacing: 0;
    margin: 0 0 var(--space-6);
    color: var(--text-primary);
  }

  .about-hero-sub {
    max-width: 720px;
    color: var(--text-secondary);
    font-size: clamp(1.1rem, 2vw, 1.35rem);
    line-height: 1.7;
  }

  .origin-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(280px, 0.8fr);
    gap: var(--space-12);
    align-items: center;
  }

  .origin-copy h2,
  .section-header h2,
  .specialty-panel h2,
  .cta-panel h2 {
    margin: 0 0 var(--space-4);
    font-size: clamp(2rem, 4vw, 3.75rem);
    line-height: 1.05;
    letter-spacing: 0;
    color: var(--text-primary);
  }

  .origin-copy p,
  .specialty-panel p {
    color: var(--text-secondary);
    font-size: 1.05rem;
    line-height: 1.75;
  }

  .brand-card {
    border: 1px solid var(--border-medium);
    border-radius: 8px;
    padding: var(--space-8);
    background: var(--bg-surface);
    display: grid;
    gap: var(--space-6);
    box-shadow: var(--shadow-md);
  }

  .brand-card img {
    width: 132px;
    height: auto;
  }

  .brand-card span {
    display: block;
    color: var(--brand-primary);
    font-family: var(--font-mono);
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: var(--space-1);
  }

  .brand-card strong {
    display: block;
    color: var(--text-primary);
    font-size: 1.65rem;
    line-height: 1.15;
  }

  .section-header {
    max-width: 760px;
    margin-bottom: var(--space-8);
  }

  .systems-list {
    border-top: 1px solid var(--border-medium);
  }

  .system-row {
    display: grid;
    grid-template-columns: 72px 1fr;
    gap: var(--space-4);
    align-items: center;
    padding: var(--space-6) 0;
    border-bottom: 1px solid var(--border-medium);
  }

  .system-row span {
    color: var(--brand-accent);
    font-family: var(--font-mono);
    font-weight: 700;
  }

  .system-row strong {
    color: var(--text-primary);
    font-size: clamp(1.35rem, 3vw, 2.4rem);
    letter-spacing: 0;
  }

  .principles-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-4);
  }

  .principle-card {
    min-height: 250px;
    padding: var(--space-6);
    border: 1px solid var(--border-medium);
    border-radius: 8px;
    background: var(--bg-surface);
  }

  .principle-card h3 {
    margin: 0 0 var(--space-3);
    color: var(--text-primary);
    font-size: 1.2rem;
  }

  .principle-card p {
    color: var(--text-secondary);
    line-height: 1.65;
  }

  .specialty-panel,
  .cta-panel {
    border-radius: 8px;
    padding: var(--space-12);
    background: var(--bg-surface);
    border: 1px solid var(--border-medium);
  }

  .specialty-panel {
    max-width: 920px;
  }

  .cta-panel {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--space-8);
    align-items: center;
    background:
      linear-gradient(135deg, rgba(42, 71, 54, 0.14), transparent 48%),
      var(--bg-surface);
  }

  @media (max-width: 900px) {
    .origin-grid,
    .cta-panel {
      grid-template-columns: 1fr;
    }

    .principles-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .principles-grid {
      grid-template-columns: 1fr;
    }

    .system-row {
      grid-template-columns: 48px 1fr;
    }

    .specialty-panel,
    .cta-panel {
      padding: var(--space-6);
    }
  }
</style>
