{
  "name": "5-cypress-labs-platform",
  "version": "1.1.0",
  "description": "5 Cypress Labs - Resilient AI Automation Dashboard",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "npm install",
    "deploy": "npx wrangler pages deploy public",
    "audit": "npx lighthouse https://5cypress.com --chrome-flags='--headless --no-sandbox' --output=html --output-path=./audits/lighthouse-$(date +%Y%m%d-%H%M%S).html",
    "audit:ps": "PowerShell -ExecutionPolicy Bypass -File ./scripts/audit-lighthouse-weekly.ps1",
    "versions": "npx wrangler versions upload"
  },
  "keywords": [
    "ai-automation",
    "resilient-systems",
    "workflow-architecture",
    "5-cypress-labs"
  ],
  "author": "5 Cypress Labs",
  "license": "MIT",
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "better-sqlite3": "^12.6.2",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.3.1",
    "framer-motion": "^12.34.3",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "morgan": "^1.10.0",
    "stripe": "^20.3.1",
    "three": "^0.183.1",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "wrangler": "^3.45.0"
  }
}
