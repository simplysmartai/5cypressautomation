# DataForSEO API (for SEO Audit admin tool)
# Get credentials at: https://www.dataforseo.com/
DATAFORSEO_USERNAME=your_dataforseo_email@example.com
DATAFORSEO_PASSWORD=your_dataforseo_api_password

# OpenAI API (for AI insights in SEO Audit)
# Get your API key at: https://platform.openai.com/account/api-keys
OPENAI_API_KEY=sk-proj-...

# Perplexity MCP Server
# Get your API key at: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=pplx-...

# Nano Banana MCP Server (Gemini-powered image generation)
# Get your API key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# Stripe Payments
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_SUCCESS_URL=http://localhost:3000/seo-report.html?paid=true
STRIPE_CANCEL_URL=http://localhost:3000/seo-dashboard.html

# Admin Panel (protects /admin/* routes via HTTP Basic Auth)
ADMIN_USER=nick
ADMIN_PASS=choose-a-strong-password-here

# Path to the 5 Cypress marketing team folder (absolute path, no trailing slash)
MARKETING_TEAM_PATH=C:\Users\smart\Downloads\5cypress-marketing-team\5cypress-marketing-team

# Google PageSpeed Insights API key for /api/admin/seo-audit
GOOGLE_PAGESPEED_API_KEY=AIza...

# Calendly Integration (Personal Access Token)
# Generate at: https://calendly.com/app/personal-access-tokens
CALENDLY_TOKEN=eyJraWQ...
# Your Calendly booking page URL
CALENDLY_URL=https://calendly.com/YOUR_SLUG/discovery
# Webhook signing key — populated automatically by running:
#   node execution/register_calendly_webhook.js https://yourapp.com/api/webhooks/calendly
CALENDLY_WEBHOOK_SIGNING_KEY=

# GigClock — Freelancer Time Tracking SaaS
GC_JWT_SECRET=replace-with-64-char-random-string   # node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
GC_STRIPE_PRO_PRICE_ID=price_xxxxxxxxxxxxx          # Create $3/month recurring price in Stripe dashboard
GC_STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx        # GigClock-specific Stripe webhook secret
GC_BASE_URL=https://5cypress.com
